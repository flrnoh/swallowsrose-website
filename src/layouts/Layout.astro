---
// Fonts are imported here so they ship with every page and Vite can fingerprint them.
import '@fontsource/oswald/400.css';
import '@fontsource/oswald/700.css';
import '@fontsource-variable/inter-tight';

import '../styles/global.css';
import Nav from '../components/Nav.astro';
import { band } from '../data/site.ts';

interface Props {
  title?: string;
  description?: string;
  /** Show site chrome (nav + footer slot). Off for stripped legal sub-pages if needed. */
  chrome?: boolean;
}

const {
  title = `${band.name} — Melodic Punk Rock from Bavaria`,
  description = `Official site of ${band.name}. New album "The Beginning" out March 6, 2026 on Uncle M Music. Tour dates, music, merch.`,
  chrome = true,
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site ?? 'http://localhost');
---

<!doctype html>
<html lang="de">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="generator" content={Astro.generator} />
    <meta name="theme-color" content="#0a0a0a" />
    <meta name="color-scheme" content="dark" />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical.toString()} />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical.toString()} />
    {/* TODO: drop a real 1200x630 image at /public/img/og.jpg */}
    <meta property="og:image" content="/img/og.jpg" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content="/img/og.jpg" />

    <!-- Avoid FOUC of language toggle: set the lang attr ASAP from storage. -->
    <script is:inline>
      try {
        const lang = localStorage.getItem('sr-lang') || 'de';
        document.documentElement.lang = lang;
        document.documentElement.dataset.lang = lang;
      } catch (_) {}
    </script>
  </head>

  <body class="noise">
    {chrome && <Nav />}

    <main id="top">
      <slot />
    </main>

    <!--
      Client-side glue: DE/EN toggle + scroll reveal via IntersectionObserver.
      Kept inline to avoid a network round-trip for ~30 lines of vanilla JS.
    -->
    <script is:inline>
      (function () {
        // ---------- DE/EN toggle ----------
        const root = document.documentElement;
        const stored = (function () {
          try { return localStorage.getItem('sr-lang'); } catch (_) { return null; }
        })();
        let lang = stored === 'en' ? 'en' : 'de';
        applyLang(lang);

        function applyLang(next) {
          lang = next;
          root.lang = next;
          root.dataset.lang = next;
          document.querySelectorAll('[data-lang]').forEach((el) => {
            const isThisLang = el.getAttribute('data-lang') === next;
            if (el instanceof HTMLElement) el.hidden = !isThisLang;
          });
          document.querySelectorAll('[data-lang-toggle]').forEach((btn) => {
            const t = btn.getAttribute('data-lang-toggle');
            btn.setAttribute('aria-pressed', String(t === next));
          });
          try { localStorage.setItem('sr-lang', next); } catch (_) {}
        }

        document.addEventListener('click', (e) => {
          const target = e.target;
          if (!(target instanceof Element)) return;
          const btn = target.closest('[data-lang-toggle]');
          if (!btn) return;
          const next = btn.getAttribute('data-lang-toggle');
          if (next === 'de' || next === 'en') applyLang(next);
        });

        // ---------- Scroll reveal ----------
        const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
        const targets = document.querySelectorAll('.reveal');
        if (prefersReduced || !('IntersectionObserver' in window)) {
          targets.forEach((t) => t.classList.add('is-visible'));
        } else {
          const io = new IntersectionObserver(
            (entries) => {
              for (const entry of entries) {
                if (entry.isIntersecting) {
                  entry.target.classList.add('is-visible');
                  io.unobserve(entry.target);
                }
              }
            },
            { rootMargin: '0px 0px -10% 0px', threshold: 0.05 },
          );
          targets.forEach((t) => io.observe(t));
        }

        // ---------- Spotify click-to-load (DSGVO) ----------
        document.addEventListener('click', (e) => {
          const target = e.target;
          if (!(target instanceof Element)) return;
          const trigger = target.closest('[data-load-spotify]');
          if (!trigger) return;
          const wrap = trigger.closest('[data-spotify-wrap]');
          if (!wrap) return;
          const src = wrap.getAttribute('data-spotify-src');
          if (!src) return;
          const iframe = document.createElement('iframe');
          iframe.src = src;
          iframe.width = '100%';
          iframe.height = '352';
          iframe.loading = 'lazy';
          iframe.style.borderRadius = '0';
          iframe.style.border = '0';
          iframe.allow = 'autoplay; clipboard-write; encrypted-media; fullscreen; picture-in-picture';
          iframe.title = 'Spotify player';
          wrap.replaceChildren(iframe);
        });
      })();
    </script>
  </body>
</html>
