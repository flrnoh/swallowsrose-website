---
import { copy } from '../data/copy.ts';
import { tourDates } from '../data/site.ts';
---

<section id="tour" class="py-20 sm:py-28 border-b border-[color:var(--color-cream)]/10">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <header class="reveal mb-6">
      <div class="section-mark">
        <span>// 03 — Live</span>
        <span class="section-mark-tag">[ Tour 2026 ]</span>
      </div>
      <h2 class="display section-headline">
        <span data-lang="de">{copy.tour.headlineDE}</span>
        <span data-lang="en" hidden>{copy.tour.headlineEN}</span>
      </h2>
    </header>

    <p class="reveal max-w-2xl text-[color:var(--color-cream)]/65 mb-10">
      <span data-lang="de">{copy.tour.supportDE}</span>
      <span data-lang="en" hidden>{copy.tour.supportEN}</span>
    </p>

    {
      tourDates.length === 0 ? (
        <p class="reveal display text-2xl text-[color:var(--color-cream)]/60">
          <span data-lang="de">{copy.tour.emptyDE}</span>
          <span data-lang="en" hidden>{copy.tour.emptyEN}</span>
        </p>
      ) : (
        <ul class="divide-y divide-[color:var(--color-cream)]/10 border-y border-[color:var(--color-cream)]/10">
          {tourDates.map((d) => (
            <li
              data-tour-row
              class="reveal group grid grid-cols-12 items-center gap-4 py-5 sm:py-6 transition-colors hover:bg-[color:var(--color-ink-soft)] data-[past=true]:opacity-40 data-[past=true]:hover:bg-transparent"
            >
              <time
                datetime={d.date}
                class="col-span-12 sm:col-span-4 display text-[clamp(2rem,5vw,3.5rem)] leading-[0.95] tracking-[-0.03em] text-[color:var(--color-flame)]"
              >
                <span data-lang="de">{d.dateLabelDE}</span>
                <span data-lang="en" hidden>{d.dateLabelEN}</span>
              </time>
              <div class="col-span-7 sm:col-span-4">
                <p class="display text-2xl sm:text-3xl leading-none">{d.city}</p>
                <p class="mt-1 text-sm text-[color:var(--color-cream)]/65">{d.venue}</p>
              </div>
              <div class="col-span-12 sm:col-span-2 text-sm text-[color:var(--color-cream)]/55 uppercase tracking-[0.15em]">
                {d.note ?? ''}
              </div>
              <div data-tickets-cell class="col-span-5 sm:col-span-2 text-right">
                {d.ticketUrl ? (
                  <a
                    href={d.ticketUrl}
                    target="_blank"
                    rel="noopener"
                    class="inline-flex items-center gap-1 font-display uppercase text-sm tracking-[0.15em] linky"
                  >
                    <span data-lang="de">{copy.tour.ticketsDE}</span>
                    <span data-lang="en" hidden>{copy.tour.ticketsEN}</span>
                    <span aria-hidden="true">&rarr;</span>
                  </a>
                ) : (
                  <span class="text-xs uppercase tracking-[0.2em] text-[color:var(--color-cream)]/35">
                    <span data-lang="de">Bald</span>
                    <span data-lang="en" hidden>Soon</span>
                  </span>
                )}
              </div>
            </li>
          ))}
        </ul>
      )
    }
    {/* TODO: replace the placeholder rows in src/data/site.ts with real tour dates. */}
  </div>
</section>
