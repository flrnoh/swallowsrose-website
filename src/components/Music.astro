---
import { copy } from '../data/copy.ts';
import { spotifyEmbedSrc, links } from '../data/site.ts';
---

<section id="music" class="py-20 sm:py-28 border-b border-[color:var(--color-cream)]/10">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <header class="reveal flex items-end justify-between gap-4 mb-10">
      <h2 class="display text-[clamp(2.5rem,7vw,5.5rem)]">
        <span data-lang="de">{copy.music.headlineDE}</span>
        <span data-lang="en" hidden>{copy.music.headlineEN}</span>
      </h2>
      <span class="hidden sm:block text-xs uppercase tracking-[0.3em] text-[color:var(--color-cream)]/40">
        01 / Stream
      </span>
    </header>

    <!--
      Click-to-load Spotify player.
      TODO: replace REPLACE_WITH_SPOTIFY_ARTIST_ID in src/data/site.ts
      with the real artist ID (or swap for an album/playlist embed).
    -->
    <div
      class="reveal"
      data-spotify-wrap
      data-spotify-src={spotifyEmbedSrc}
    >
      <button
        type="button"
        data-load-spotify
        class="group w-full text-left border border-[color:var(--color-cream)]/15 bg-[color:var(--color-ink-soft)] p-6 sm:p-10 transition-colors hover:border-[color:var(--color-flame)] focus-visible:outline focus-visible:outline-2 focus-visible:outline-[color:var(--color-flame)] min-h-[200px] flex flex-col justify-between gap-6"
      >
        <div>
          <p class="font-display uppercase text-xs tracking-[0.3em] text-[color:var(--color-cream)]/50">
            Spotify
          </p>
          <p class="mt-3 display text-2xl sm:text-3xl group-hover:text-[color:var(--color-flame)] transition-colors">
            <span data-lang="de">{copy.music.spotifyLoadDE}</span>
            <span data-lang="en" hidden>{copy.music.spotifyLoadEN}</span>
            <span aria-hidden="true" class="inline-block ml-2 group-hover:translate-x-1 transition-transform">&rarr;</span>
          </p>
        </div>
        <p class="text-sm text-[color:var(--color-cream)]/55 max-w-xl">
          <span data-lang="de">{copy.music.spotifyConsentDE}</span>
          <span data-lang="en" hidden>{copy.music.spotifyConsentEN}</span>
        </p>
      </button>
    </div>

    <div class="reveal mt-10 flex flex-wrap items-center gap-x-8 gap-y-3">
      <span class="font-display uppercase text-xs tracking-[0.3em] text-[color:var(--color-cream)]/40">
        <span data-lang="de">{copy.music.otherDE}</span>
        <span data-lang="en" hidden>{copy.music.otherEN}</span>
      </span>
      <a href={links.appleMusic} target="_blank" rel="noopener" class="linky font-display uppercase tracking-[0.15em]">Apple Music</a>
      <a href={links.youtube} target="_blank" rel="noopener" class="linky font-display uppercase tracking-[0.15em]">YouTube</a>
    </div>
  </div>
</section>
