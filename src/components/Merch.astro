---
import { copy } from '../data/copy.ts';
import { links } from '../data/site.ts';

// TODO: swap with real product images at /public/img/merch/*.jpg
const products = [
  { src: '/img/merch/product-1.jpg', alt: 'The Beginning — Vinyl LP' },
  { src: '/img/merch/product-2.jpg', alt: 'Swallow’s Rose — Tour Shirt' },
  { src: '/img/merch/product-3.jpg', alt: 'Swallow’s Rose — Logo Hoodie' },
];
---

<section id="merch" class="py-20 sm:py-28 border-b border-[color:var(--color-cream)]/10">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <header class="reveal flex items-end justify-between gap-4 mb-10">
      <h2 class="display text-[clamp(2.5rem,7vw,5.5rem)]">
        <span data-lang="de">{copy.merch.headlineDE}</span>
        <span data-lang="en" hidden>{copy.merch.headlineEN}</span>
      </h2>
      <span class="hidden sm:block text-xs uppercase tracking-[0.3em] text-[color:var(--color-cream)]/40">
        04 / Shop
      </span>
    </header>

    <div class="grid lg:grid-cols-12 gap-8">
      <div class="reveal lg:col-span-5">
        <p class="text-lg text-[color:var(--color-cream)]/80 leading-relaxed">
          <span data-lang="de">{copy.merch.bodyDE}</span>
          <span data-lang="en" hidden>{copy.merch.bodyEN}</span>
        </p>
        <a
          href={links.shop}
          target="_blank"
          rel="noopener"
          class="btn btn-primary mt-8"
        >
          <span data-lang="de">{copy.merch.ctaDE}</span>
          <span data-lang="en" hidden>{copy.merch.ctaEN}</span>
          <span aria-hidden="true">&rarr;</span>
        </a>
      </div>

      <ul class="reveal lg:col-span-7 grid grid-cols-3 gap-3 sm:gap-4">
        {
          products.map((p) => (
            <li class="aspect-square bg-[color:var(--color-ink-soft)] border border-[color:var(--color-cream)]/10 overflow-hidden">
              <img
                src={p.src}
                alt={p.alt}
                width="600"
                height="600"
                loading="lazy"
                decoding="async"
                class="w-full h-full object-cover opacity-80 hover:opacity-100 transition-opacity"
                onerror="this.style.display='none'"
              />
            </li>
          ))
        }
      </ul>
    </div>
  </div>
</section>
