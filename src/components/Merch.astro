---
import { copy } from '../data/copy.ts';
import { links } from '../data/site.ts';

// Each tile links straight to its product detail page on the Uncle M shop.
const products = [
  {
    src: '/img/merch/product-1.jpg',
    alt: 'The Beginning — Vinyl LP (Pink Magenta)',
    labelDE: 'Vinyl LP',
    labelEN: 'Vinyl LP',
    href: 'https://shop.uncle-m.com/lp/9271/swallows-s-rose-the-beginning-lp/pink-magenta?c=2233',
  },
  {
    src: '/img/merch/product-2.jpg',
    alt: 'Swallow’s Rose — T-Shirt „The Beginning"',
    labelDE: 'T-Shirt',
    labelEN: 'T-Shirt',
    href: 'https://shop.uncle-m.com/textil/shirts/9303/swallows-s-rose-t-shirt-the-beginning-weiss?c=2233',
  },
  {
    src: '/img/merch/product-3.jpg',
    alt: 'Swallow’s Rose — Snapback Cap „The Beginning"',
    labelDE: 'Snapback',
    labelEN: 'Snapback',
    href: 'https://shop.uncle-m.com/stuff/9302/swallows-s-rose-snapback-cap-the-beginning?c=2233',
  },
  {
    src: '/img/merch/product-4.jpg',
    alt: 'Swallow’s Rose — Socken „The Beginning"',
    labelDE: 'Socken',
    labelEN: 'Socks',
    href: 'https://shop.uncle-m.com/stuff/9304/swallows-s-rose-socken-the-beginning-weiss?c=2233',
  },
];
---

<section id="merch" class="py-20 sm:py-28 border-b border-[color:var(--color-cream)]/10">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <header class="reveal mb-8 sm:mb-12">
      <div class="section-mark">
        <span>// 04 — Shop</span>
        <span class="section-mark-tag">[ Uncle M ]</span>
      </div>
      <h2 class="display section-headline">
        <span data-lang="de">{copy.merch.headlineDE}</span>
        <span data-lang="en" hidden>{copy.merch.headlineEN}</span>
      </h2>
    </header>

    <div class="grid lg:grid-cols-12 gap-8">
      <div class="reveal lg:col-span-5">
        <p class="text-lg text-[color:var(--color-cream)]/80 leading-relaxed">
          <span data-lang="de">{copy.merch.bodyDE}</span>
          <span data-lang="en" hidden>{copy.merch.bodyEN}</span>
        </p>
        <a
          href={links.shop}
          target="_blank"
          rel="noopener"
          class="btn btn-primary mt-8"
        >
          <span data-lang="de">{copy.merch.ctaDE}</span>
          <span data-lang="en" hidden>{copy.merch.ctaEN}</span>
          <span aria-hidden="true">&rarr;</span>
        </a>
      </div>

      <ul class="reveal lg:col-span-7 grid grid-cols-2 sm:grid-cols-4 gap-3 sm:gap-4">
        {
          products.map((p) => (
            <li class="polaroid">
              <a
                href={p.href}
                target="_blank"
                rel="noopener"
                class="group block border-[3px] border-[color:var(--color-cream)] hover:border-[color:var(--color-flame)] shadow-[5px_5px_0_var(--color-ink-soft)] hover:shadow-[7px_7px_0_var(--color-flame)] transition-all"
              >
                <div class="aspect-square bg-white overflow-hidden">
                  <img
                    src={p.src}
                    alt={p.alt}
                    width="600"
                    height="600"
                    loading="lazy"
                    decoding="async"
                    class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-[1.03]"
                    onerror="this.style.display='none'"
                  />
                </div>
                <p class="px-3 py-2 font-display uppercase text-[11px] tracking-[0.18em] text-[color:var(--color-cream)]/70 group-hover:text-[color:var(--color-flame)] transition-colors">
                  <span data-lang="de">{p.labelDE}</span>
                  <span data-lang="en" hidden>{p.labelEN}</span>
                  <span aria-hidden="true" class="float-right">&rarr;</span>
                </p>
              </a>
            </li>
          ))
        }
      </ul>
    </div>
  </div>
</section>
