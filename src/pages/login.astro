---
// Crew login. Invite-only magic link — enter your email, get a link, you're in.
import Layout from '../layouts/Layout.astro';
---

<Layout title="Crew-Login — Swallow's Rose" chrome={false}>
  <section class="grid min-h-[100dvh] place-items-center px-6 py-16">
    <div class="w-full max-w-sm">
      <a
        href="/"
        class="mb-10 inline-block text-xs uppercase tracking-[0.2em] text-cream-soft transition-colors hover:text-flame"
      >
        ← <span data-lang="de">zurück zur Seite</span><span data-lang="en" hidden>back to site</span>
      </a>

      <p class="mb-2 text-xs uppercase tracking-[0.3em] text-flame">Crew</p>
      <h1 class="text-5xl">Login</h1>
      <p class="mt-4 text-sm text-cream-soft">
        <span data-lang="de">Nur für Bandmitglieder. Gib deine E-Mail ein — du bekommst einen Login-Link geschickt.</span>
        <span data-lang="en" hidden>Members only. Enter your email — we'll send you a login link.</span>
      </p>

      <form id="login-form" class="mt-8 flex flex-col gap-3">
        <label for="email" class="sr-only">E-Mail</label>
        <input
          id="email"
          name="email"
          type="email"
          required
          autocomplete="email"
          placeholder="du@swallowsrose.com"
          class="w-full rounded-lg border border-cream/15 bg-ink-soft px-4 py-3 text-cream outline-none transition-colors placeholder:text-cream/30 focus:border-flame"
        />
        <button
          id="submit"
          type="submit"
          class="w-full rounded-lg bg-flame px-4 py-3 font-display text-lg uppercase tracking-wide text-ink transition-colors hover:bg-flame-soft disabled:opacity-50"
        >
          <span data-lang="de">Login-Link schicken</span><span data-lang="en" hidden>Send login link</span>
        </button>
      </form>

      <p id="msg" role="status" class="mt-6 text-sm text-teal" hidden></p>
    </div>
  </section>
</Layout>

<script>
  import { authClient } from '../lib/auth-client';

  const form = document.getElementById('login-form') as HTMLFormElement;
  const emailInput = document.getElementById('email') as HTMLInputElement;
  const submit = document.getElementById('submit') as HTMLButtonElement;
  const msg = document.getElementById('msg') as HTMLParagraphElement;

  const t = (de: string, en: string) =>
    (document.documentElement.lang === 'en' ? en : de);

  function showMsg(text: string, ok = true) {
    msg.textContent = text;
    msg.style.color = ok ? 'var(--color-teal)' : 'var(--color-flame)';
    msg.hidden = false;
  }

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    const email = emailInput.value.trim().toLowerCase();
    if (!email) return;

    submit.disabled = true;
    submit.textContent = t('Schicke …', 'Sending …');

    try {
      const { error } = await authClient.signIn.magicLink({
        email,
        callbackURL: '/backend',
      });
      if (error) throw new Error(error.message ?? 'unknown');
      form.hidden = true;
      showMsg(
        t(
          `Wenn ${email} zur Crew gehört, ist gleich ein Login-Link im Postfach. Schau auch im Spam nach.`,
          `If ${email} is on the crew, a login link is on its way. Check your spam too.`,
        ),
      );
    } catch (err) {
      submit.disabled = false;
      submit.textContent = t('Login-Link schicken', 'Send login link');
      showMsg(
        t('Da lief was schief. Nochmal versuchen?', 'Something went wrong. Try again?'),
        false,
      );
      console.error(err);
    }
  });
</script>
