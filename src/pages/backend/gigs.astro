---
// Gig booking pipeline — inquiries → offers → confirmed → played.
// Any logged-in member may edit. Confirmed public gigs feed the tour calendar.
export const prerender = false;

import Layout from '../../layouts/Layout.astro';
import { listGigs, STATUSES } from '../../lib/events';

const user = Astro.locals.user!;
const gigs = await listGigs();

const statusLabel: Record<string, string> = {
  anfrage: 'Anfrage',
  angebot: 'Angebot',
  bestaetigt: 'Bestätigt',
  gespielt: 'Gespielt',
  abgesagt: 'Abgesagt',
};
const statusColor: Record<string, string> = {
  anfrage: 'text-cream/45',
  angebot: 'text-teal',
  bestaetigt: 'text-flame',
  gespielt: 'text-cream/45',
  abgesagt: 'text-cream/30',
};

const tz = 'Europe/Berlin';
const fmtDay = (d: Date) =>
  new Intl.DateTimeFormat('de-DE', { weekday: 'short', day: '2-digit', month: 'short', year: 'numeric', timeZone: tz }).format(d);
const fmtTime = (d: Date) =>
  new Intl.DateTimeFormat('de-DE', { hour: '2-digit', minute: '2-digit', timeZone: tz }).format(d);

// Group gigs by status in pipeline order.
const groups = STATUSES.map((s) => ({
  status: s,
  label: statusLabel[s],
  items: gigs.filter((g) => g.status === s),
}));

const clientGigs = gigs.map((g) => ({
  id: g.id,
  title: g.title,
  startAt: g.startAt.toISOString(),
  location: g.location ?? '',
  city: g.city ?? '',
  ticketUrl: g.ticketUrl ?? '',
  notes: g.notes ?? '',
  isPublic: g.isPublic,
  status: g.status,
  fee: g.fee,
  contactName: g.contactName ?? '',
  contactEmail: g.contactEmail ?? '',
  contactPhone: g.contactPhone ?? '',
}));
---

<Layout title="Gig-Pipeline — Swallow's Rose Crew" chrome={false}>
  <section class="mx-auto min-h-[100dvh] max-w-3xl px-6 py-16">
    <a href="/backend" class="mb-8 inline-block text-xs uppercase tracking-[0.2em] text-cream-soft transition-colors hover:text-flame">
      ← Crew-Bereich
    </a>

    <p class="mb-2 text-xs uppercase tracking-[0.3em] text-flame">Booking</p>
    <h1 class="text-5xl">Gig-Pipeline</h1>
    <p class="mt-3 text-sm text-cream-soft">Anfrage → Angebot → Bestätigt → Gespielt. Bestätigte öffentliche Gigs erscheinen im Tourkalender.</p>

    <!-- Anlegen / Bearbeiten -->
    <form id="gig-form" class="mt-8 rounded-xl border border-cream/10 bg-ink-soft/50 p-5">
      <h2 id="form-title" class="text-2xl">Neue Anfrage</h2>
      <input type="hidden" id="g-id" />
      <div class="mt-4 grid grid-cols-1 gap-3 sm:grid-cols-2">
        <input id="g-title" required placeholder="Titel (z. B. Sommerfest XY)" autocomplete="off"
          class="rounded-lg border border-cream/15 bg-ink px-4 py-3 text-cream outline-none placeholder:text-cream/30 focus:border-flame sm:col-span-2" />
        <label class="flex flex-col gap-1 text-xs uppercase tracking-wider text-cream/40">Datum
          <input id="g-start" required type="datetime-local"
            class="rounded-lg border border-cream/15 bg-ink px-4 py-2.5 text-cream outline-none focus:border-flame" />
        </label>
        <select id="g-status" class="mt-auto rounded-lg border border-cream/15 bg-ink px-4 py-3 text-cream outline-none focus:border-flame">
          {STATUSES.map((s) => <option value={s} selected={s === 'anfrage'}>{statusLabel[s]}</option>)}
        </select>
        <input id="g-city" placeholder="Stadt" autocomplete="off"
          class="rounded-lg border border-cream/15 bg-ink px-4 py-3 text-cream outline-none placeholder:text-cream/30 focus:border-flame" />
        <input id="g-location" placeholder="Venue / Ort" autocomplete="off"
          class="rounded-lg border border-cream/15 bg-ink px-4 py-3 text-cream outline-none placeholder:text-cream/30 focus:border-flame" />
        <input id="g-fee" type="number" min="0" step="1" placeholder="Gage (€)" autocomplete="off"
          class="rounded-lg border border-cream/15 bg-ink px-4 py-3 text-cream outline-none placeholder:text-cream/30 focus:border-flame" />
        <input id="g-ticket" placeholder="Ticket-Link (optional)" autocomplete="off"
          class="rounded-lg border border-cream/15 bg-ink px-4 py-3 text-cream outline-none placeholder:text-cream/30 focus:border-flame" />
        <input id="g-contact-name" placeholder="Ansprechpartner" autocomplete="off"
          class="rounded-lg border border-cream/15 bg-ink px-4 py-3 text-cream outline-none placeholder:text-cream/30 focus:border-flame" />
        <input id="g-contact-email" placeholder="Kontakt E-Mail" autocomplete="off"
          class="rounded-lg border border-cream/15 bg-ink px-4 py-3 text-cream outline-none placeholder:text-cream/30 focus:border-flame" />
        <input id="g-contact-phone" placeholder="Kontakt Telefon" autocomplete="off"
          class="rounded-lg border border-cream/15 bg-ink px-4 py-3 text-cream outline-none placeholder:text-cream/30 focus:border-flame" />
        <textarea id="g-notes" placeholder="Notizen (optional)" rows="2"
          class="rounded-lg border border-cream/15 bg-ink px-4 py-3 text-cream outline-none placeholder:text-cream/30 focus:border-flame sm:col-span-2"></textarea>
      </div>
      <div class="mt-4">
        <label class="flex items-center gap-2 text-sm text-cream-soft">
          <input id="g-public" type="checkbox" class="accent-flame" /> Öffentlich (im Tourkalender, sobald bestätigt)
        </label>
      </div>
      <div class="mt-5 flex items-center gap-4">
        <button id="g-submit" type="submit"
          class="rounded-lg bg-flame px-5 py-3 font-display text-lg uppercase tracking-wide text-ink transition-colors hover:bg-flame-soft disabled:opacity-50">
          Speichern
        </button>
        <button id="g-cancel" type="button" hidden class="text-xs uppercase tracking-[0.15em] text-cream-soft hover:text-flame">Abbrechen</button>
        <p id="g-msg" role="status" class="text-sm text-teal" hidden></p>
      </div>
    </form>

    <!-- Pipeline -->
    <div class="mt-10">
      {gigs.length === 0 && <p class="text-sm text-cream/40">Noch keine Gigs — leg oben die erste Anfrage an.</p>}
      {
        groups.filter((g) => g.items.length).map((g) => (
          <div class="mb-6">
            <p class={`mb-2 text-xs uppercase tracking-[0.2em] ${statusColor[g.status]}`}>
              {g.label} ({g.items.length})
            </p>
            <ul class="flex flex-col gap-2">
              {g.items.map((gig) => (
                <li class={`flex flex-wrap items-center gap-x-4 gap-y-2 rounded-xl border border-cream/10 bg-ink-soft/50 p-4 ${gig.status === 'abgesagt' ? 'opacity-50' : ''}`} data-gig data-id={gig.id}>
                  <div class="w-24 shrink-0">
                    <div class="text-sm text-flame">{fmtDay(gig.startAt)}</div>
                    <div class="text-xs text-cream/40">{gig.allDay ? '' : fmtTime(gig.startAt)}</div>
                  </div>
                  <div class="min-w-0 flex-1">
                    <div class="flex items-center gap-2">
                      <span class="truncate text-lg">{gig.title}</span>
                      {gig.isPublic && <span class="text-[10px] uppercase tracking-[0.2em] text-teal">öffentlich</span>}
                    </div>
                    <div class="truncate text-sm text-cream-soft">
                      {[gig.city, gig.location].filter(Boolean).join(' · ')}
                      {gig.fee != null ? ` · ${gig.fee} €` : ''}
                    </div>
                    {(gig.contactName || gig.contactEmail || gig.contactPhone) && (
                      <div class="truncate text-xs text-cream/40">
                        {[gig.contactName, gig.contactEmail, gig.contactPhone].filter(Boolean).join(' · ')}
                      </div>
                    )}
                  </div>
                  <div class="flex items-center gap-2">
                    <select data-status class="rounded-lg border border-cream/15 bg-ink px-2 py-1.5 text-xs text-cream outline-none focus:border-flame">
                      {STATUSES.map((s) => (
                        <option value={s} selected={s === gig.status}>{statusLabel[s]}</option>
                      ))}
                    </select>
                    <button data-edit class="rounded-lg border border-cream/15 px-3 py-1.5 text-xs uppercase tracking-[0.15em] text-cream-soft transition-colors hover:border-flame hover:text-flame">Bearb.</button>
                    <button data-del class="rounded-lg border border-cream/15 px-3 py-1.5 text-xs uppercase tracking-[0.15em] text-cream-soft transition-colors hover:border-flame hover:text-flame">Löschen</button>
                  </div>
                </li>
              ))}
            </ul>
          </div>
        ))
      }
    </div>
  </section>

  <script id="gigs-data" type="application/json" set:html={JSON.stringify(clientGigs)}></script>
</Layout>

<script>
  type Gig = {
    id: string; title: string; startAt: string; location: string; city: string;
    ticketUrl: string; notes: string; isPublic: boolean; status: string; fee: number | null;
    contactName: string; contactEmail: string; contactPhone: string;
  };
  const gigs: Gig[] = JSON.parse(document.getElementById('gigs-data')!.textContent || '[]');
  const $ = (id: string) => document.getElementById(id) as HTMLInputElement;

  const form = document.getElementById('gig-form') as HTMLFormElement;
  const msg = document.getElementById('g-msg') as HTMLParagraphElement;
  const submit = document.getElementById('g-submit') as HTMLButtonElement;
  const cancel = document.getElementById('g-cancel') as HTMLButtonElement;
  const formTitle = document.getElementById('form-title') as HTMLElement;

  const toLocalInput = (iso: string) => {
    const d = new Date(iso);
    const p = (n: number) => String(n).padStart(2, '0');
    return `${d.getFullYear()}-${p(d.getMonth() + 1)}-${p(d.getDate())}T${p(d.getHours())}:${p(d.getMinutes())}`;
  };
  const showMsg = (t: string, ok = true) => {
    msg.textContent = t;
    msg.style.color = ok ? 'var(--color-teal)' : 'var(--color-flame)';
    msg.hidden = false;
  };
  async function post(url: string, body: unknown) {
    const res = await fetch(url, { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(body) });
    return { ok: res.ok, data: await res.json().catch(() => ({})) };
  }

  const FIELDS = ['g-title', 'g-start', 'g-city', 'g-location', 'g-fee', 'g-ticket', 'g-contact-name', 'g-contact-email', 'g-contact-phone', 'g-notes'];
  function resetForm() {
    $('g-id').value = '';
    FIELDS.forEach((id) => (($(id) as HTMLInputElement).value = ''));
    ($('g-status') as unknown as HTMLSelectElement).value = 'anfrage';
    $('g-public').checked = false;
    formTitle.textContent = 'Neue Anfrage';
    cancel.hidden = true;
    msg.hidden = true;
  }
  function fillForm(g: Gig) {
    $('g-id').value = g.id;
    $('g-title').value = g.title;
    $('g-start').value = toLocalInput(g.startAt);
    ($('g-status') as unknown as HTMLSelectElement).value = g.status;
    $('g-city').value = g.city;
    $('g-location').value = g.location;
    $('g-fee').value = g.fee != null ? String(g.fee) : '';
    $('g-ticket').value = g.ticketUrl;
    $('g-contact-name').value = g.contactName;
    $('g-contact-email').value = g.contactEmail;
    $('g-contact-phone').value = g.contactPhone;
    ($('g-notes') as unknown as HTMLTextAreaElement).value = g.notes;
    $('g-public').checked = g.isPublic;
    formTitle.textContent = 'Gig bearbeiten';
    cancel.hidden = false;
    form.scrollIntoView({ behavior: 'smooth', block: 'start' });
  }
  cancel.addEventListener('click', resetForm);

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    const start = $('g-start').value;
    if (!$('g-title').value.trim() || !start) return;
    const feeRaw = $('g-fee').value.trim();
    const payload: Record<string, unknown> = {
      id: $('g-id').value || undefined,
      type: 'gig',
      title: $('g-title').value.trim(),
      startAt: new Date(start).toISOString(),
      status: ($('g-status') as unknown as HTMLSelectElement).value,
      city: $('g-city').value.trim(),
      location: $('g-location').value.trim(),
      fee: feeRaw === '' ? null : Number(feeRaw),
      ticketUrl: $('g-ticket').value.trim(),
      contactName: $('g-contact-name').value.trim(),
      contactEmail: $('g-contact-email').value.trim(),
      contactPhone: $('g-contact-phone').value.trim(),
      notes: ($('g-notes') as unknown as HTMLTextAreaElement).value.trim(),
      isPublic: $('g-public').checked,
    };
    submit.disabled = true;
    submit.textContent = 'Speichert …';
    const { ok, data } = await post(payload.id ? '/api/events/update' : '/api/events/create', payload);
    submit.disabled = false;
    submit.textContent = 'Speichern';
    if (ok) {
      showMsg('Gespeichert.');
      setTimeout(() => location.reload(), 600);
    } else showMsg(data.error ?? 'Speichern fehlgeschlagen.', false);
  });

  document.querySelectorAll('[data-gig]').forEach((li) => {
    const id = (li as HTMLElement).dataset.id!;
    li.querySelector('[data-status]')?.addEventListener('change', async (e) => {
      const sel = e.target as HTMLSelectElement;
      const { ok, data } = await post('/api/events/status', { id, status: sel.value });
      if (ok) location.reload();
      else alert(data.error ?? 'Status konnte nicht geändert werden.');
    });
    li.querySelector('[data-edit]')?.addEventListener('click', () => {
      const g = gigs.find((x) => x.id === id);
      if (g) fillForm(g);
    });
    li.querySelector('[data-del]')?.addEventListener('click', async () => {
      const title = li.querySelector('.truncate')?.textContent ?? 'diesen Gig';
      if (!confirm(`„${title}" wirklich löschen?`)) return;
      const { ok, data } = await post('/api/events/delete', { id });
      if (ok) li.remove();
      else alert(data.error ?? 'Löschen fehlgeschlagen.');
    });
  });
</script>
