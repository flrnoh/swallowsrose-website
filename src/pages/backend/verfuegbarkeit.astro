---
// Verfügbarkeits-Ampel — per member ja/vielleicht/nein for each upcoming event.
export const prerender = false;

import Layout from '../../layouts/Layout.astro';
import { listUpcomingEvents } from '../../lib/events';
import { listAllMembers, getAvailabilityForEvents } from '../../lib/availability';

const user = Astro.locals.user!;
const events = await listUpcomingEvents();
const members = await listAllMembers();
const rows = await getAvailabilityForEvents(events.map((e) => e.id));

// availMap[eventId][userId] = status
const availMap: Record<string, Record<string, string>> = {};
for (const r of rows) (availMap[r.eventId] ??= {})[r.userId] = r.status;

const typeLabel: Record<string, string> = { gig: 'Gig', probe: 'Probe', sonstiges: 'Termin' };
const tz = 'Europe/Berlin';
const fmtDay = (d: Date) =>
  new Intl.DateTimeFormat('de-DE', { weekday: 'short', day: '2-digit', month: 'short', year: 'numeric', timeZone: tz }).format(d);
const fmtTime = (d: Date) =>
  new Intl.DateTimeFormat('de-DE', { hour: '2-digit', minute: '2-digit', timeZone: tz }).format(d);

// Static class maps (shared with the client script — keep in sync).
const chipClass: Record<string, string> = {
  ja: 'border-teal/40 bg-teal/15 text-teal',
  vielleicht: 'border-cream/25 text-cream/70',
  nein: 'border-flame/40 bg-flame/15 text-flame',
  offen: 'border-cream/10 text-cream/30',
};
const glyph: Record<string, string> = { ja: '✓', vielleicht: '?', nein: '✗', offen: '·' };
---

<Layout title="Verfügbarkeit — Swallow's Rose Crew" chrome={false}>
  <section class="mx-auto min-h-[100dvh] max-w-3xl px-6 py-16">
    <a href="/backend" class="mb-8 inline-block text-xs uppercase tracking-[0.2em] text-cream-soft transition-colors hover:text-flame">
      ← Crew-Bereich
    </a>

    <p class="mb-2 text-xs uppercase tracking-[0.3em] text-flame">Crew</p>
    <h1 class="text-5xl">Verfügbarkeit</h1>
    <p class="mt-3 text-sm text-cream-soft">Sag pro Termin ob du kannst — alle sehen die Übersicht.</p>

    {events.length === 0 && <p class="mt-10 text-sm text-cream/40">Keine anstehenden Termine.</p>}

    <div class="mt-10 flex flex-col gap-4">
      {
        events.map((e) => {
          const mine = availMap[e.id]?.[user.id] ?? 'offen';
          return (
            <div class="rounded-xl border border-cream/10 bg-ink-soft/50 p-5" data-event-card data-id={e.id}>
              <div class="flex flex-wrap items-baseline justify-between gap-2">
                <div>
                  <span class="text-[10px] uppercase tracking-[0.2em] text-cream/40">{typeLabel[e.type]}</span>
                  <h2 class="text-2xl leading-tight">{e.title}</h2>
                  <p class="text-sm text-cream-soft">
                    {fmtDay(e.startAt)}{!e.allDay && ` · ${fmtTime(e.startAt)}`}
                    {(e.city || e.location) && ` · ${[e.city, e.location].filter(Boolean).join(', ')}`}
                  </p>
                </div>
              </div>

              {/* Deine Antwort */}
              <div class="mt-4 flex gap-2" data-buttons>
                {(['ja', 'vielleicht', 'nein'] as const).map((s) => (
                  <button
                    data-set={s}
                    class:list={[
                      'rounded-lg border px-4 py-2 text-sm font-display uppercase tracking-wide transition-colors',
                      mine === s
                        ? s === 'ja'
                          ? 'border-teal bg-teal text-ink'
                          : s === 'vielleicht'
                            ? 'border-cream bg-cream text-ink'
                            : 'border-flame bg-flame text-ink'
                        : s === 'ja'
                          ? 'border-teal/40 text-teal hover:bg-teal/10'
                          : s === 'vielleicht'
                            ? 'border-cream/30 text-cream/70 hover:bg-cream/10'
                            : 'border-flame/40 text-flame hover:bg-flame/10',
                    ]}
                  >
                    {s === 'ja' ? 'Ja' : s === 'vielleicht' ? 'Vielleicht' : 'Nein'}
                  </button>
                ))}
              </div>

              {/* Crew-Übersicht */}
              <div class="mt-4 flex flex-wrap gap-2">
                {members.map((m) => {
                  const st = availMap[e.id]?.[m.id] ?? 'offen';
                  return (
                    <span
                      data-chip
                      data-user={m.id}
                      class={`rounded-full border px-3 py-1 text-xs ${chipClass[st]}`}
                    >
                      <span data-glyph>{glyph[st]}</span> {m.name}{m.id === user.id ? ' (du)' : ''}
                    </span>
                  );
                })}
              </div>
            </div>
          );
        })
      }
    </div>
  </section>

  <script id="me" type="application/json" set:html={JSON.stringify({ id: user.id })}></script>
</Layout>

<script>
  const me: string = JSON.parse(document.getElementById('me')!.textContent || '{}').id;

  const glyph: Record<string, string> = { ja: '✓', vielleicht: '?', nein: '✗', offen: '·' };
  const chipClass: Record<string, string> = {
    ja: 'border-teal/40 bg-teal/15 text-teal',
    vielleicht: 'border-cream/25 text-cream/70',
    nein: 'border-flame/40 bg-flame/15 text-flame',
    offen: 'border-cream/10 text-cream/30',
  };
  const btnActive: Record<string, string> = {
    ja: 'border-teal bg-teal text-ink',
    vielleicht: 'border-cream bg-cream text-ink',
    nein: 'border-flame bg-flame text-ink',
  };
  const btnInactive: Record<string, string> = {
    ja: 'border-teal/40 text-teal hover:bg-teal/10',
    vielleicht: 'border-cream/30 text-cream/70 hover:bg-cream/10',
    nein: 'border-flame/40 text-flame hover:bg-flame/10',
  };
  const BTN_BASE = 'rounded-lg border px-4 py-2 text-sm font-display uppercase tracking-wide transition-colors';
  const CHIP_BASE = 'rounded-full border px-3 py-1 text-xs';

  document.querySelectorAll('[data-event-card]').forEach((card) => {
    const eventId = (card as HTMLElement).dataset.id!;
    const buttons = [...card.querySelectorAll('[data-set]')] as HTMLButtonElement[];

    buttons.forEach((btn) => {
      btn.addEventListener('click', async () => {
        const status = btn.dataset.set!;
        buttons.forEach((b) => (b.disabled = true));
        const res = await fetch('/api/availability/set', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ eventId, status }),
        });
        const data = await res.json().catch(() => ({}));
        buttons.forEach((b) => (b.disabled = false));
        if (!res.ok) {
          alert(data.error ?? 'Konnte nicht speichern.');
          return;
        }
        // Update my buttons
        buttons.forEach((b) => {
          const s = b.dataset.set!;
          b.className = `${BTN_BASE} ${s === status ? btnActive[s] : btnInactive[s]}`;
        });
        // Update my chip
        const chip = card.querySelector(`[data-chip][data-user="${me}"]`) as HTMLElement | null;
        if (chip) {
          chip.className = `${CHIP_BASE} ${chipClass[status]}`;
          const g = chip.querySelector('[data-glyph]');
          if (g) g.textContent = glyph[status];
        }
      });
    });
  });
</script>
