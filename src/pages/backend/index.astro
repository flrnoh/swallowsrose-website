---
// Crew area — the authenticated landing page. Middleware guarantees a session,
// so Astro.locals.user is always set here. Future modules (gig pipeline,
// setlists, finances …) hang off this shell.
export const prerender = false;

import Layout from '../../layouts/Layout.astro';

const user = Astro.locals.user!;
const firstName = user.name?.split(' ')[0] ?? 'Crew';

// Roadmap tiles — placeholders until each module lands.
const modules = [
  { title: 'Gig-Pipeline', desc: 'Anfrage → bestätigt → gespielt' },
  { title: 'Verfügbarkeit', desc: 'Ein-Klick-Ampel pro Show' },
  { title: 'Setlists', desc: 'Songbibliothek & Drag-and-drop' },
  { title: 'Gig-Sheets', desc: 'Anfahrt, Load-in, Rider' },
  { title: 'Finanzen', desc: 'Gagen-Split & Rechnungen' },
  { title: 'Kontakte', desc: 'Venues, Booker, Technik' },
];
---

<Layout title="Crew-Bereich — Swallow's Rose" chrome={false}>
  <section class="mx-auto min-h-[100dvh] max-w-3xl px-6 py-16">
    <header class="flex items-start justify-between gap-4">
      <div>
        <p class="mb-2 text-xs uppercase tracking-[0.3em] text-flame">Crew-Bereich</p>
        <h1 class="text-5xl">Servus, {firstName}</h1>
        <p class="mt-3 text-sm text-cream-soft">
          Eingeloggt als {user.email}{user.role ? ` · ${user.role}` : ''}
        </p>
      </div>
      <button
        id="logout"
        class="shrink-0 rounded-lg border border-cream/15 px-4 py-2 text-xs uppercase tracking-[0.2em] text-cream-soft transition-colors hover:border-flame hover:text-flame"
      >
        Logout
      </button>
    </header>

    <a
      href="/backend/kalender"
      class="mt-10 block rounded-xl border border-flame/40 bg-flame/10 p-5 transition-colors hover:border-flame"
    >
      <div class="flex items-center justify-between">
        <h2 class="text-2xl">Kalender</h2>
        <span class="text-xl text-flame">→</span>
      </div>
      <p class="mt-2 text-sm text-cream-soft">Gigs, Proben & Termine — teilen und in den eigenen Kalender abonnieren</p>
    </a>

    {
      user.role === 'bandleader' && (
        <a
          href="/backend/mitglieder"
          class="mt-4 block rounded-xl border border-cream/15 bg-ink-soft/50 p-5 transition-colors hover:border-flame"
        >
          <div class="flex items-center justify-between">
            <h2 class="text-2xl">Mitglieder verwalten</h2>
            <span class="text-xl text-flame">→</span>
          </div>
          <p class="mt-2 text-sm text-cream-soft">Bandmitglieder einladen, Rollen setzen, entfernen</p>
        </a>
      )
    }

    <div class="mt-6 grid grid-cols-1 gap-4 sm:grid-cols-2">
      {
        modules.map((m) => (
          <div class="rounded-xl border border-cream/10 bg-ink-soft/50 p-5">
            <div class="flex items-center justify-between">
              <h2 class="text-2xl">{m.title}</h2>
              <span class="text-[10px] uppercase tracking-[0.2em] text-cream/30">bald</span>
            </div>
            <p class="mt-2 text-sm text-cream-soft">{m.desc}</p>
          </div>
        ))
      }
    </div>

    <p class="mt-12 text-xs text-cream/30">
      Das ist erst mal die Tür. Die Module oben bauen wir Schritt für Schritt aus.
    </p>
  </section>
</Layout>

<script>
  import { authClient } from '../../lib/auth-client';
  const btn = document.getElementById('logout') as HTMLButtonElement;
  btn.addEventListener('click', async () => {
    btn.disabled = true;
    await authClient.signOut();
    window.location.href = '/login';
  });
</script>
