---
// Printable A4 invoice. Standalone light document (NOT the dark marketing shell)
// so it prints clean on paper / saves to PDF via the browser. Auth-guarded by
// middleware (/backend/*). No external requests — egress-free.
export const prerender = false;

import {
  getInvoice, getInvoiceSettings, computeTotals, fmtEuro, fmtInvoiceDate, dueDate,
  STATUS_LABEL, type Status, type TaxMode,
} from '../../../lib/invoices';

const { id } = Astro.params;
const inv = id ? await getInvoice(id) : null;
if (!inv) return Astro.redirect('/backend/finanzen');

const s = getInvoiceSettings();
const totals = computeTotals(inv.items, inv.taxMode as TaxMode, inv.taxRatePercent);
const due = dueDate(inv.issueDate, inv.dueDays);
const isKlein = inv.taxMode === 'kleinunternehmer';
const senderOneLine = `${s.senderName} · ${s.senderLines.join(', ')}`;
---

<!doctype html>
<html lang="de">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Rechnung {inv.number} — {inv.recipientName}</title>
    <style>
      :root { --ink: #1a1a1a; --muted: #666; --line: #ddd; --accent: #c8503c; }
      * { box-sizing: border-box; }
      html, body { margin: 0; padding: 0; background: #f3f3f3; color: var(--ink);
        font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
        font-size: 12px; line-height: 1.5; }
      .toolbar { max-width: 820px; margin: 16px auto 0; display: flex; gap: 12px; justify-content: flex-end; padding: 0 12px; }
      .toolbar a, .toolbar button { font-size: 13px; padding: 8px 16px; border-radius: 8px; border: 1px solid #bbb;
        background: #fff; color: #333; cursor: pointer; text-decoration: none; }
      .toolbar button.primary { background: var(--accent); border-color: var(--accent); color: #fff; }
      .warn { max-width: 820px; margin: 12px auto 0; padding: 10px 14px; border-radius: 8px;
        background: #fff4e5; border: 1px solid #f0c890; color: #8a5a00; font-size: 12px; }
      .sheet { max-width: 820px; margin: 16px auto 40px; background: #fff; padding: 56px 60px;
        box-shadow: 0 2px 16px rgba(0,0,0,.08); min-height: 1000px; }
      .head { display: flex; justify-content: space-between; align-items: flex-start; gap: 24px; }
      .sender h1 { font-size: 20px; margin: 0 0 4px; }
      .sender .lines, .contact-lines { color: var(--muted); font-size: 11px; }
      .meta { text-align: right; font-size: 11px; color: var(--muted); }
      .meta b { color: var(--ink); }
      .addr-return { font-size: 9px; color: var(--muted); border-bottom: 1px solid var(--line); padding-bottom: 3px; margin-bottom: 8px; }
      .recipient { margin-top: 48px; }
      .recipient .name { font-weight: 600; font-size: 13px; }
      .recipient .addr { white-space: pre-line; color: #333; }
      .title-row { margin-top: 36px; display: flex; align-items: baseline; gap: 16px; }
      .title-row h2 { font-size: 22px; margin: 0; }
      .title-row .no { color: var(--muted); }
      .facts { margin-top: 6px; color: var(--muted); font-size: 11px; }
      .facts span { margin-right: 18px; }
      .intro { margin-top: 22px; white-space: pre-line; }
      table { width: 100%; border-collapse: collapse; margin-top: 22px; }
      th, td { text-align: left; padding: 9px 8px; }
      thead th { border-bottom: 2px solid var(--ink); font-size: 10px; text-transform: uppercase; letter-spacing: .04em; }
      tbody td { border-bottom: 1px solid var(--line); vertical-align: top; }
      .num { text-align: right; white-space: nowrap; font-variant-numeric: tabular-nums; }
      .pos { color: var(--muted); width: 28px; }
      .totals { margin-top: 18px; margin-left: auto; width: 56%; }
      .totals .row { display: flex; justify-content: space-between; padding: 5px 8px; }
      .totals .grand { border-top: 2px solid var(--ink); font-weight: 700; font-size: 15px; margin-top: 4px; }
      .note { margin-top: 30px; white-space: pre-line; }
      .klein { margin-top: 18px; font-style: italic; color: #333; }
      .pay { margin-top: 34px; border-top: 1px solid var(--line); padding-top: 16px; font-size: 11px; color: #333; }
      .pay .grid { display: grid; grid-template-columns: auto 1fr; gap: 2px 14px; margin-top: 6px; }
      .pay .grid div:nth-child(odd) { color: var(--muted); }
      .foot { margin-top: 40px; border-top: 1px solid var(--line); padding-top: 12px; color: var(--muted);
        font-size: 10px; display: flex; flex-wrap: wrap; gap: 4px 20px; }
      @media print {
        html, body { background: #fff; }
        .toolbar, .warn { display: none; }
        .sheet { box-shadow: none; margin: 0; max-width: none; padding: 0; min-height: 0; }
        @page { size: A4; margin: 18mm; }
      }
    </style>
  </head>
  <body>
    <div class="toolbar">
      <a href="/backend/finanzen">← Finanzen</a>
      <button class="primary" onclick="window.print()">Drucken / als PDF speichern</button>
    </div>

    {s.isPlaceholder && (
      <div class="warn">
        ⚠️ Absenderdaten sind noch Platzhalter. Korbinian muss die Band-Adresse, Steuernummer und
        Bankverbindung in der Vercel-Umgebungsvariable <b>INVOICE_SETTINGS</b> hinterlegen, bevor
        diese Rechnung rausgeht.
      </div>
    )}

    <div class="sheet">
      <div class="head">
        <div class="sender">
          <h1>{s.senderName}</h1>
          <div class="lines">{s.senderLines.join(' · ')}</div>
        </div>
        <div class="meta">
          <div>Status: <b>{STATUS_LABEL[inv.status as Status]}</b></div>
          {s.email && <div>{s.email}</div>}
          {s.phone && <div>{s.phone}</div>}
          {s.website && <div>{s.website}</div>}
          {s.taxNumber && s.taxNumber !== '—' && <div>Steuer-Nr.: {s.taxNumber}</div>}
          {s.vatId && <div>USt-IdNr.: {s.vatId}</div>}
        </div>
      </div>

      <div class="recipient">
        <div class="addr-return">{senderOneLine}</div>
        <div class="name">{inv.recipientName}</div>
        {inv.recipientAddress && <div class="addr">{inv.recipientAddress}</div>}
        {inv.recipientEmail && <div class="contact-lines">{inv.recipientEmail}</div>}
      </div>

      <div class="title-row">
        <h2>Rechnung</h2>
        <span class="no">Nr. {inv.number}</span>
      </div>
      <div class="facts">
        <span>Rechnungsdatum: <b>{fmtInvoiceDate(inv.issueDate)}</b></span>
        {inv.serviceDate && <span>Leistung: <b>{inv.serviceDate}</b></span>}
        {due && <span>Zahlbar bis: <b>{fmtInvoiceDate(due)}</b></span>}
      </div>

      {inv.intro && <p class="intro">{inv.intro}</p>}

      <table>
        <thead>
          <tr>
            <th class="pos">Pos</th>
            <th>Beschreibung</th>
            <th class="num">Menge</th>
            <th class="num">Einzelpreis</th>
            <th class="num">Betrag</th>
          </tr>
        </thead>
        <tbody>
          {inv.items.map((it, i) => (
            <tr>
              <td class="pos">{i + 1}</td>
              <td>{it.description}</td>
              <td class="num">{it.quantity}</td>
              <td class="num">{fmtEuro(it.unitPriceCents)}</td>
              <td class="num">{fmtEuro(it.quantity * it.unitPriceCents)}</td>
            </tr>
          ))}
        </tbody>
      </table>

      <div class="totals">
        {!isKlein && (
          <>
            <div class="row"><span>Nettobetrag</span><span class="num">{fmtEuro(totals.netCents)}</span></div>
            <div class="row"><span>zzgl. {inv.taxRatePercent} % USt</span><span class="num">{fmtEuro(totals.taxCents)}</span></div>
          </>
        )}
        <div class="row grand"><span>{isKlein ? 'Gesamtbetrag' : 'Rechnungsbetrag'}</span><span class="num">{fmtEuro(totals.grossCents)}</span></div>
      </div>

      {isKlein && <p class="klein">{s.kleinunternehmerNote}</p>}

      {inv.notes && <p class="note">{inv.notes}</p>}
      {!inv.notes && s.paymentNote && <p class="note">{s.paymentNote}</p>}

      {(s.iban || s.bankName) && (
        <div class="pay">
          <b>Bankverbindung</b>
          <div class="grid">
            {(s.accountHolder || s.senderName) && <><div>Kontoinhaber</div><div>{s.accountHolder || s.senderName}</div></>}
            {s.bankName && <><div>Bank</div><div>{s.bankName}</div></>}
            {s.iban && <><div>IBAN</div><div>{s.iban}</div></>}
            {s.bic && <><div>BIC</div><div>{s.bic}</div></>}
          </div>
        </div>
      )}

      <div class="foot">
        <span>{s.senderName}</span>
        {s.taxNumber && s.taxNumber !== '—' && <span>Steuer-Nr. {s.taxNumber}</span>}
        {s.vatId && <span>USt-IdNr. {s.vatId}</span>}
        {s.email && <span>{s.email}</span>}
      </div>
    </div>
  </body>
</html>
