---
// Crew member management — bandleader-only. List, invite, set role, remove.
export const prerender = false;

import Layout from '../../layouts/Layout.astro';
import { listMembers, ROLES } from '../../lib/crew';

const user = Astro.locals.user!;
if (user.role !== 'bandleader') {
  return Astro.redirect('/backend');
}

const members = await listMembers();

const roleLabels: Record<string, string> = {
  bandleader: 'Bandleader',
  member: 'Mitglied',
  sub: 'Aushilfe',
};
---

<Layout title="Mitglieder — Swallow's Rose Crew" chrome={false}>
  <section class="mx-auto min-h-[100dvh] max-w-3xl px-6 py-16">
    <a
      href="/backend"
      class="mb-8 inline-block text-xs uppercase tracking-[0.2em] text-cream-soft transition-colors hover:text-flame"
    >
      ← Crew-Bereich
    </a>

    <p class="mb-2 text-xs uppercase tracking-[0.3em] text-flame">Verwaltung</p>
    <h1 class="text-5xl">Mitglieder</h1>
    <p class="mt-3 text-sm text-cream-soft">
      Lade Bandmitglieder ein — sie bekommen sofort einen Login-Link per Mail.
    </p>

    <!-- Einladen -->
    <form id="invite-form" class="mt-10 rounded-xl border border-cream/10 bg-ink-soft/50 p-5">
      <h2 class="text-2xl">Neues Mitglied einladen</h2>
      <div class="mt-4 grid grid-cols-1 gap-3 sm:grid-cols-2">
        <input id="in-name" required placeholder="Name" autocomplete="off"
          class="rounded-lg border border-cream/15 bg-ink px-4 py-3 text-cream outline-none transition-colors placeholder:text-cream/30 focus:border-flame" />
        <input id="in-email" required type="email" placeholder="E-Mail" autocomplete="off"
          class="rounded-lg border border-cream/15 bg-ink px-4 py-3 text-cream outline-none transition-colors placeholder:text-cream/30 focus:border-flame" />
        <input id="in-instrument" placeholder="Instrument / Rolle (optional)" autocomplete="off"
          class="rounded-lg border border-cream/15 bg-ink px-4 py-3 text-cream outline-none transition-colors placeholder:text-cream/30 focus:border-flame" />
        <select id="in-role"
          class="rounded-lg border border-cream/15 bg-ink px-4 py-3 text-cream outline-none transition-colors focus:border-flame">
          {ROLES.map((r) => <option value={r} selected={r === 'member'}>{roleLabels[r]}</option>)}
        </select>
      </div>
      <div class="mt-4 flex items-center gap-4">
        <button id="in-submit" type="submit"
          class="rounded-lg bg-flame px-5 py-3 font-display text-lg uppercase tracking-wide text-ink transition-colors hover:bg-flame-soft disabled:opacity-50">
          Einladen
        </button>
        <p id="invite-msg" role="status" class="text-sm text-teal" hidden></p>
      </div>
    </form>

    <!-- Liste -->
    <div class="mt-10">
      <h2 class="mb-4 text-2xl">Crew ({members.length})</h2>
      <ul class="flex flex-col gap-3">
        {
          members.map((m) => (
            <li
              class="flex flex-wrap items-center gap-x-4 gap-y-3 rounded-xl border border-cream/10 bg-ink-soft/50 p-4"
              data-member
              data-id={m.id}
            >
              <div class="min-w-0 flex-1">
                <div class="flex items-center gap-2">
                  <span class="truncate text-lg">{m.name}</span>
                  {m.id === user.id && (
                    <span class="text-[10px] uppercase tracking-[0.2em] text-flame">du</span>
                  )}
                  <span
                    class={`text-[10px] uppercase tracking-[0.2em] ${m.active ? 'text-teal' : 'text-cream/30'}`}
                  >
                    {m.active ? 'aktiv' : 'eingeladen'}
                  </span>
                </div>
                <div class="truncate text-sm text-cream-soft">
                  {m.email}
                  {m.instrument ? ` · ${m.instrument}` : ''}
                </div>
              </div>

              <select
                data-role
                class="rounded-lg border border-cream/15 bg-ink px-3 py-2 text-sm text-cream outline-none focus:border-flame"
              >
                {ROLES.map((r) => (
                  <option value={r} selected={r === m.role}>
                    {roleLabels[r]}
                  </option>
                ))}
              </select>

              {m.id !== user.id && (
                <button
                  data-remove
                  title="Mitglied entfernen"
                  class="rounded-lg border border-cream/15 px-3 py-2 text-xs uppercase tracking-[0.15em] text-cream-soft transition-colors hover:border-flame hover:text-flame"
                >
                  Entfernen
                </button>
              )}
            </li>
          ))
        }
      </ul>
    </div>
  </section>
</Layout>

<script>
  async function post(url: string, body: unknown) {
    const res = await fetch(url, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(body),
    });
    const data = await res.json().catch(() => ({}));
    return { ok: res.ok, data };
  }

  // — Einladen —
  const form = document.getElementById('invite-form') as HTMLFormElement;
  const msg = document.getElementById('invite-msg') as HTMLParagraphElement;
  const submit = document.getElementById('in-submit') as HTMLButtonElement;

  function showMsg(text: string, ok = true) {
    msg.textContent = text;
    msg.style.color = ok ? 'var(--color-teal)' : 'var(--color-flame)';
    msg.hidden = false;
  }

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    const name = (document.getElementById('in-name') as HTMLInputElement).value.trim();
    const email = (document.getElementById('in-email') as HTMLInputElement).value.trim();
    const instrument = (document.getElementById('in-instrument') as HTMLInputElement).value.trim();
    const role = (document.getElementById('in-role') as HTMLSelectElement).value;
    if (!name || !email) return;

    submit.disabled = true;
    submit.textContent = 'Lädt …';
    const { ok, data } = await post('/api/crew/invite', { name, email, instrument, role });
    submit.disabled = false;
    submit.textContent = 'Einladen';

    if (ok) {
      showMsg(`${name} eingeladen — Login-Link ging an ${email}.`);
      setTimeout(() => location.reload(), 900);
    } else {
      showMsg(data.error ?? 'Einladung fehlgeschlagen.', false);
    }
  });

  // — Rolle ändern / Entfernen —
  document.querySelectorAll('[data-member]').forEach((li) => {
    const id = (li as HTMLElement).dataset.id!;

    li.querySelector('[data-role]')?.addEventListener('change', async (e) => {
      const sel = e.target as HTMLSelectElement;
      const prev = sel.dataset.prev ?? sel.value;
      const { ok, data } = await post('/api/crew/role', { userId: id, role: sel.value });
      if (!ok) {
        alert(data.error ?? 'Konnte Rolle nicht ändern.');
        sel.value = prev;
      } else {
        sel.dataset.prev = sel.value;
      }
    });

    li.querySelector('[data-remove]')?.addEventListener('click', async () => {
      const name = li.querySelector('.truncate')?.textContent ?? 'dieses Mitglied';
      if (!confirm(`${name} wirklich entfernen?`)) return;
      const { ok, data } = await post('/api/crew/remove', { userId: id });
      if (ok) li.remove();
      else alert(data.error ?? 'Konnte nicht entfernen.');
    });
  });
</script>
