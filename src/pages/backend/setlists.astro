---
// Setlists — the band's song library + named, ordered setlists. Any logged-in
// member may edit. Song editor here; per-setlist song order lives on [id].astro.
export const prerender = false;

import Layout from '../../layouts/Layout.astro';
import { listSongs, listSetlists, fmtDuration } from '../../lib/setlists';
import { listUpcomingEvents } from '../../lib/events';

const user = Astro.locals.user!;
const songs = await listSongs();
const setlists = await listSetlists();
const events = await listUpcomingEvents();

const tz = 'Europe/Berlin';
const fmtDay = (d: Date) =>
  new Intl.DateTimeFormat('de-DE', { day: '2-digit', month: 'short', year: 'numeric', timeZone: tz }).format(d);

const eventOptions = events.map((e) => ({
  id: e.id,
  label: `${fmtDay(e.startAt)} · ${e.title}${e.city ? ` (${e.city})` : ''}`,
}));
const eventLabel = new Map(eventOptions.map((o) => [o.id, o.label]));

const activeCount = songs.filter((s) => s.active).length;
const inputBase =
  'rounded-lg border border-cream/15 bg-ink px-4 py-3 text-cream outline-none placeholder:text-cream/30 focus:border-flame';
---

<Layout title="Setlists — Swallow's Rose Crew" chrome={false}>
  <section class="mx-auto min-h-[100dvh] max-w-3xl px-6 py-16">
    <a href="/backend" class="mb-8 inline-block text-xs uppercase tracking-[0.2em] text-cream-soft transition-colors hover:text-flame">
      ← Crew-Bereich
    </a>

    <p class="mb-2 text-xs uppercase tracking-[0.3em] text-flame">Repertoire</p>
    <h1 class="text-5xl">Setlists</h1>
    <p class="mt-3 text-sm text-cream-soft">
      Songbibliothek pflegen und daraus Setlists bauen — Reihenfolge per Drag-and-drop im Setlist-Editor.
    </p>

    <!-- ── Setlists ─────────────────────────────────────────── -->
    <div class="mt-10 flex items-baseline justify-between">
      <h2 class="text-3xl">Deine Setlists</h2>
      <span class="text-xs uppercase tracking-[0.2em] text-cream/40">{setlists.length}</span>
    </div>

    <form id="setlist-form" class="mt-4 rounded-xl border border-cream/10 bg-ink-soft/50 p-5">
      <div class="grid grid-cols-1 gap-3 sm:grid-cols-2">
        <input id="sl-title" required placeholder="Setlist-Name (z. B. Festival 45 Min)" autocomplete="off"
          class={`${inputBase} sm:col-span-2`} />
        <select id="sl-event" class={`${inputBase} sm:col-span-2`}>
          <option value="">— optional: mit Gig verknüpfen —</option>
          {eventOptions.map((o) => <option value={o.id}>{o.label}</option>)}
        </select>
      </div>
      <div class="mt-4 flex items-center gap-4">
        <button id="sl-submit" type="submit"
          class="rounded-lg bg-flame px-5 py-3 font-display text-lg uppercase tracking-wide text-ink transition-colors hover:bg-flame-soft disabled:opacity-50">
          Setlist anlegen
        </button>
        <p id="sl-msg" role="status" class="text-sm text-teal" hidden></p>
      </div>
    </form>

    <div class="mt-5">
      {setlists.length === 0 && <p class="text-sm text-cream/40">Noch keine Setlist — leg oben die erste an.</p>}
      <ul class="flex flex-col gap-2">
        {setlists.map((sl) => (
          <li class="flex items-center gap-3 rounded-xl border border-cream/10 bg-ink-soft/50 p-4" data-setlist data-id={sl.id}>
            <a href={`/backend/setlists/${sl.id}`} class="min-w-0 flex-1">
              <div class="truncate text-lg">{sl.title}</div>
              <div class="truncate text-sm text-cream-soft">
                {sl.songCount} Song{sl.songCount === 1 ? '' : 's'}
                {sl.durationSeconds > 0 ? ` · ${fmtDuration(sl.durationSeconds)} Min` : ''}
                {sl.eventId && eventLabel.has(sl.eventId) ? ` · ${eventLabel.get(sl.eventId)}` : ''}
              </div>
            </a>
            <a href={`/backend/setlists/${sl.id}`}
              class="shrink-0 rounded-lg border border-cream/15 px-3 py-1.5 text-xs uppercase tracking-[0.15em] text-cream-soft transition-colors hover:border-flame hover:text-flame">
              Öffnen →
            </a>
            <button data-del-setlist class="shrink-0 rounded-lg border border-cream/15 px-3 py-1.5 text-xs uppercase tracking-[0.15em] text-cream-soft transition-colors hover:border-flame hover:text-flame">
              Löschen
            </button>
          </li>
        ))}
      </ul>
    </div>

    <!-- ── Song-Bibliothek ─────────────────────────────────── -->
    <div class="mt-14 flex items-baseline justify-between">
      <h2 class="text-3xl">Songbibliothek</h2>
      <span class="text-xs uppercase tracking-[0.2em] text-cream/40">{activeCount} aktiv / {songs.length}</span>
    </div>

    <form id="song-form" class="mt-4 rounded-xl border border-cream/10 bg-ink-soft/50 p-5">
      <input type="hidden" id="song-id" />
      <h3 id="song-form-title" class="text-xl">Song hinzufügen</h3>
      <div class="mt-3 grid grid-cols-1 gap-3 sm:grid-cols-6">
        <input id="song-title" required placeholder="Titel" autocomplete="off" class={`${inputBase} sm:col-span-3`} />
        <input id="song-artist" placeholder="Original (nur bei Covern)" autocomplete="off" class={`${inputBase} sm:col-span-2`} />
        <input id="song-duration" placeholder="Länge (m:ss)" autocomplete="off" class={`${inputBase} sm:col-span-1`} />
        <input id="song-notes" placeholder="Notizen (Tuning, Key, Cues …)" autocomplete="off" class={`${inputBase} sm:col-span-6`} />
      </div>
      <div class="mt-4 flex items-center gap-4">
        <button id="song-submit" type="submit"
          class="rounded-lg bg-flame px-5 py-2.5 font-display text-base uppercase tracking-wide text-ink transition-colors hover:bg-flame-soft disabled:opacity-50">
          Speichern
        </button>
        <button id="song-cancel" type="button" hidden class="text-xs uppercase tracking-[0.15em] text-cream-soft hover:text-flame">Abbrechen</button>
        <p id="song-msg" role="status" class="text-sm text-teal" hidden></p>
      </div>
    </form>

    <div class="mt-5">
      {songs.length === 0 && <p class="text-sm text-cream/40">Bibliothek ist leer.</p>}
      <ul class="flex flex-col gap-1.5">
        {songs.map((s) => (
          <li class={`flex flex-wrap items-center gap-x-3 gap-y-1 rounded-lg border border-cream/10 bg-ink-soft/40 px-4 py-2.5 ${s.active ? '' : 'opacity-50'}`}
            data-song data-id={s.id}
            data-title={s.title} data-artist={s.artist ?? ''} data-duration={s.durationSeconds ?? ''} data-notes={s.notes ?? ''} data-active={s.active ? '1' : ''}>
            <span class="min-w-0 flex-1 truncate">
              {s.title}
              {s.artist && <span class="text-cream/40"> · {s.artist}</span>}
              {s.notes && <span class="ml-2 text-xs text-cream/40">{s.notes}</span>}
            </span>
            <span class="shrink-0 text-sm tabular-nums text-cream-soft">{fmtDuration(s.durationSeconds) || '—'}</span>
            <button data-toggle-active class="shrink-0 rounded border border-cream/15 px-2 py-1 text-[10px] uppercase tracking-[0.15em] text-cream-soft transition-colors hover:border-flame hover:text-flame">
              {s.active ? 'Aktiv' : 'Inaktiv'}
            </button>
            <button data-edit-song class="shrink-0 rounded border border-cream/15 px-2 py-1 text-[10px] uppercase tracking-[0.15em] text-cream-soft transition-colors hover:border-flame hover:text-flame">Bearb.</button>
            <button data-del-song class="shrink-0 rounded border border-cream/15 px-2 py-1 text-[10px] uppercase tracking-[0.15em] text-cream-soft transition-colors hover:border-flame hover:text-flame">Löschen</button>
          </li>
        ))}
      </ul>
    </div>
  </section>
</Layout>

<script>
  const $ = (id: string) => document.getElementById(id) as HTMLInputElement;
  async function post(url: string, body: unknown) {
    const res = await fetch(url, { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(body) });
    return { ok: res.ok, data: await res.json().catch(() => ({})) };
  }
  function parseDuration(text: string): number | null {
    const t = text.trim();
    if (!t) return null;
    if (/^\d+$/.test(t)) return Number(t) * 60;
    const m = t.match(/^(\d+):([0-5]?\d)$/);
    return m ? Number(m[1]) * 60 + Number(m[2]) : null;
  }
  const showMsg = (el: HTMLElement, t: string, ok = true) => {
    el.textContent = t;
    el.style.color = ok ? 'var(--color-teal)' : 'var(--color-flame)';
    el.hidden = false;
  };

  // ── Setlist create + delete ──
  const slForm = document.getElementById('setlist-form') as HTMLFormElement;
  const slMsg = document.getElementById('sl-msg') as HTMLElement;
  const slSubmit = document.getElementById('sl-submit') as HTMLButtonElement;
  slForm.addEventListener('submit', async (e) => {
    e.preventDefault();
    const title = $('sl-title').value.trim();
    if (!title) return;
    slSubmit.disabled = true;
    const { ok, data } = await post('/api/setlist/save', {
      title,
      eventId: ($('sl-event') as unknown as HTMLSelectElement).value || null,
    });
    slSubmit.disabled = false;
    if (ok && data.id) {
      window.location.href = `/backend/setlists/${data.id}`;
    } else showMsg(slMsg, data.error ?? 'Konnte nicht anlegen.', false);
  });

  document.querySelectorAll('[data-setlist]').forEach((li) => {
    const id = (li as HTMLElement).dataset.id!;
    li.querySelector('[data-del-setlist]')?.addEventListener('click', async () => {
      const title = li.querySelector('.truncate')?.textContent ?? 'diese Setlist';
      if (!confirm(`„${title}" wirklich löschen? Die Songbibliothek bleibt erhalten.`)) return;
      const { ok, data } = await post('/api/setlist/delete', { id });
      if (ok) li.remove();
      else alert(data.error ?? 'Löschen fehlgeschlagen.');
    });
  });

  // ── Song library CRUD ──
  const songForm = document.getElementById('song-form') as HTMLFormElement;
  const songMsg = document.getElementById('song-msg') as HTMLElement;
  const songSubmit = document.getElementById('song-submit') as HTMLButtonElement;
  const songCancel = document.getElementById('song-cancel') as HTMLButtonElement;
  const songFormTitle = document.getElementById('song-form-title') as HTMLElement;

  function resetSongForm() {
    $('song-id').value = '';
    ['song-title', 'song-artist', 'song-duration', 'song-notes'].forEach((id) => ($(id).value = ''));
    songFormTitle.textContent = 'Song hinzufügen';
    songCancel.hidden = true;
    songMsg.hidden = true;
  }
  songCancel.addEventListener('click', resetSongForm);

  songForm.addEventListener('submit', async (e) => {
    e.preventDefault();
    const title = $('song-title').value.trim();
    if (!title) return;
    const durTxt = $('song-duration').value.trim();
    if (durTxt && parseDuration(durTxt) === null) {
      showMsg(songMsg, 'Länge im Format m:ss angeben (z. B. 3:45).', false);
      return;
    }
    const id = $('song-id').value;
    songSubmit.disabled = true;
    const { ok, data } = await post('/api/setlist/song', {
      action: id ? 'update' : 'create',
      id: id || undefined,
      title,
      artist: $('song-artist').value.trim(),
      durationSeconds: parseDuration(durTxt),
      notes: $('song-notes').value.trim(),
    });
    songSubmit.disabled = false;
    if (ok) {
      showMsg(songMsg, 'Gespeichert.');
      setTimeout(() => location.reload(), 500);
    } else showMsg(songMsg, data.error ?? 'Speichern fehlgeschlagen.', false);
  });

  function fmtSecs(v: string): string {
    const n = Number(v);
    if (!v || !n) return '';
    return `${Math.floor(n / 60)}:${String(n % 60).padStart(2, '0')}`;
  }

  document.querySelectorAll('[data-song]').forEach((li) => {
    const el = li as HTMLElement;
    const id = el.dataset.id!;
    el.querySelector('[data-edit-song]')?.addEventListener('click', () => {
      $('song-id').value = id;
      $('song-title').value = el.dataset.title || '';
      $('song-artist').value = el.dataset.artist || '';
      $('song-duration').value = fmtSecs(el.dataset.duration || '');
      $('song-notes').value = el.dataset.notes || '';
      songFormTitle.textContent = 'Song bearbeiten';
      songCancel.hidden = false;
      songForm.scrollIntoView({ behavior: 'smooth', block: 'center' });
    });
    el.querySelector('[data-toggle-active]')?.addEventListener('click', async () => {
      const nowActive = el.dataset.active === '1';
      const { ok, data } = await post('/api/setlist/song', { action: 'update', id, title: el.dataset.title, active: !nowActive });
      if (ok) location.reload();
      else alert(data.error ?? 'Konnte nicht ändern.');
    });
    el.querySelector('[data-del-song]')?.addEventListener('click', async () => {
      if (!confirm(`„${el.dataset.title}" aus der Bibliothek löschen? Der Song verschwindet auch aus allen Setlists.`)) return;
      const { ok, data } = await post('/api/setlist/song', { action: 'delete', id });
      if (ok) el.remove();
      else alert(data.error ?? 'Löschen fehlgeschlagen.');
    });
  });
</script>
