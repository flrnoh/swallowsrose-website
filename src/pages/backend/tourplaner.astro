---
// Tour planner (Phase 1) — the band's confirmed gigs plotted on a schematic
// DACH map as a route, with straight-line (Luftlinie) leg distances. Read-only
// view; the generative planner + nearby suggestions come in later phases.
export const prerender = false;

import Layout from '../../layouts/Layout.astro';
import { listGigs, CONFIRMED_STATUSES } from '../../lib/events';
import { geocode, haversineKm, projectUnit, MAP_ASPECT, type LatLng } from '../../lib/geo';
import { bookingUrl, mapsUrl } from '../../lib/hotels';

const gigs = await listGigs();
const real = gigs.filter((g) => CONFIRMED_STATUSES.includes(g.status as never));

// Geocodable, chronological — these are the route stops.
const stops = real
  .map((g) => ({ gig: g, coord: geocode(g.city) }))
  .filter((s): s is { gig: (typeof real)[number]; coord: LatLng } => s.coord !== null)
  .sort((a, b) => a.gig.startAt.getTime() - b.gig.startAt.getTime());
const skipped = real.filter((g) => g.city && !geocode(g.city)).length;

// Leg distances (Luftlinie) + total.
const legs = stops.map((s, i) => (i === 0 ? 0 : Math.round(haversineKm(stops[i - 1].coord, s.coord))));
const totalKm = legs.reduce((a, b) => a + b, 0);

// Map geometry.
const W = 420;
const H = Math.round(W / MAP_ASPECT);
const PAD = 26;
const pts = stops.map((s) => {
  const [ux, uy] = projectUnit(s.coord);
  return { x: +(PAD + ux * (W - 2 * PAD)).toFixed(1), y: +(PAD + uy * (H - 2 * PAD)).toFixed(1) };
});
const routeD = pts.map((p, i) => `${i === 0 ? 'M' : 'L'}${p.x} ${p.y}`).join(' ');

const tz = 'Europe/Berlin';
const fmtDay = (d: Date) =>
  new Intl.DateTimeFormat('de-DE', { weekday: 'short', day: '2-digit', month: 'short', timeZone: tz }).format(d);
const period =
  stops.length > 1
    ? `${fmtDay(stops[0].gig.startAt)} – ${fmtDay(stops[stops.length - 1].gig.startAt)}`
    : stops.length === 1
      ? fmtDay(stops[0].gig.startAt)
      : '—';
---

<Layout title="Tourplaner — Swallow's Rose Crew" chrome={false}>
  <section class="mx-auto min-h-[100dvh] max-w-3xl px-6 py-16">
    <a href="/backend" class="mb-8 inline-block text-xs uppercase tracking-[0.2em] text-cream-soft transition-colors hover:text-flame">
      ← Crew-Bereich
    </a>

    <p class="mb-2 text-xs uppercase tracking-[0.3em] text-flame">Routing</p>
    <h1 class="text-5xl">Tourplaner</h1>
    <p class="mt-3 text-sm text-cream-soft">Bestätigte Gigs als Route auf der DACH-Karte, mit Luftlinien-Distanzen.</p>

    <a href="/backend/tourplaner/generator" class="mt-5 inline-flex items-center gap-2 rounded-lg bg-flame px-5 py-3 font-display text-lg uppercase tracking-wide text-ink transition-colors hover:bg-flame-soft">
      Tour generieren →
    </a>

    {
      stops.length === 0 ? (
        <p class="mt-10 text-sm text-cream/40">Noch keine bestätigten Gigs mit verortbarer Stadt — leg welche in der Gig-Pipeline an.</p>
      ) : (
        <>
          <div class="mt-8 grid grid-cols-3 gap-3">
            <div class="rounded-xl bg-ink-soft/60 p-4">
              <div class="text-xs uppercase tracking-wider text-cream/40">Stopps</div>
              <div class="mt-1 text-3xl">{stops.length}</div>
            </div>
            <div class="rounded-xl bg-ink-soft/60 p-4">
              <div class="text-xs uppercase tracking-wider text-cream/40">Luftlinie</div>
              <div class="mt-1 text-3xl">{totalKm.toLocaleString('de-DE')} km</div>
            </div>
            <div class="rounded-xl bg-ink-soft/60 p-4">
              <div class="text-xs uppercase tracking-wider text-cream/40">Zeitraum</div>
              <div class="mt-1 text-lg leading-tight">{period}</div>
            </div>
          </div>

          <div class="mt-4 rounded-xl border border-cream/10 bg-ink-soft/40 p-3">
            <svg viewBox={`0 0 ${W} ${H}`} class="mx-auto block h-auto w-full max-w-sm" role="img" aria-label="Karte der Tour-Route">
              <rect x="0.5" y="0.5" width={W - 1} height={H - 1} rx="12" fill="none" stroke="rgb(255 255 255 / 0.06)" />
              {[0.25, 0.5, 0.75].map((f) => (
                <>
                  <line x1={0} y1={f * H} x2={W} y2={f * H} stroke="rgb(255 255 255 / 0.05)" stroke-dasharray="2 9" />
                  <line x1={f * W} y1={0} x2={f * W} y2={H} stroke="rgb(255 255 255 / 0.05)" stroke-dasharray="2 9" />
                </>
              ))}
              <path d={routeD} fill="none" stroke="var(--color-flame)" stroke-width="2" stroke-linejoin="round" stroke-linecap="round" opacity="0.85" />
              {pts.map((p, i) => (
                <g>
                  <circle cx={p.x} cy={p.y} r="8.5" fill="var(--color-flame)" />
                  <text x={p.x} y={p.y + 3.5} text-anchor="middle" font-size="10" font-weight="600" fill="var(--color-ink)">
                    {i + 1}
                  </text>
                </g>
              ))}
            </svg>
            {skipped > 0 && (
              <p class="mt-2 text-center text-[11px] text-cream/30">{skipped} Gig(s) ohne verortbare Stadt nicht auf der Karte</p>
            )}
          </div>

          <ol class="mt-8 flex flex-col gap-2">
            {stops.map((s, i) => (
              <li>
                {i > 0 && (
                  <div class="flex items-center gap-2 py-1 pl-5 text-xs text-cream/30">
                    <span class="text-flame/60">↓</span> {legs[i].toLocaleString('de-DE')} km
                  </div>
                )}
                <div class="flex flex-wrap items-baseline gap-x-3 gap-y-1 rounded-xl border border-cream/10 bg-ink-soft/50 p-4">
                  <span class="flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-flame font-display text-sm text-ink">{i + 1}</span>
                  <span class="w-16 shrink-0 font-mono text-xs text-cream/40">{fmtDay(s.gig.startAt)}</span>
                  <span class="text-lg">{s.gig.city}</span>
                  <span class="text-sm text-cream-soft">· {s.gig.title}{s.gig.location && s.gig.location !== s.gig.title ? ` · ${s.gig.location}` : ''}</span>
                  <span class="ml-auto flex shrink-0 items-center gap-3 text-xs">
                    <span class="text-cream/30">Hotels:</span>
                    <a href={bookingUrl(s.gig.city!, s.gig.startAt)} target="_blank" rel="noopener noreferrer" class="text-teal transition-colors hover:text-flame">Booking ↗</a>
                    <a href={mapsUrl(s.gig.city!, s.coord)} target="_blank" rel="noopener noreferrer" class="text-teal transition-colors hover:text-flame">Maps ↗</a>
                  </span>
                </div>
              </li>
            ))}
          </ol>
        </>
      )
    }
  </section>
</Layout>
