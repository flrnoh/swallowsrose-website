---
// Gig-Sheets — the show-day day sheet per confirmed gig (load-in, schedule,
// directions, rider …). Any logged-in member may edit. One sheet per gig.
export const prerender = false;

import Layout from '../../layouts/Layout.astro';
import { listSheetGigs, getSheetsForEvents, SHEET_FIELDS } from '../../lib/gigsheets';

const user = Astro.locals.user!;
const gigs = await listSheetGigs();
const sheets = await getSheetsForEvents(gigs.map((g) => g.id));

// sheetMap[eventId] = row
const sheetMap: Record<string, Record<string, string | null>> = {};
for (const s of sheets) sheetMap[s.eventId] = s as unknown as Record<string, string | null>;

const now = Date.now();
const upcoming = gigs.filter((g) => g.startAt.getTime() >= now - 12 * 3600 * 1000);
const past = gigs.filter((g) => g.startAt.getTime() < now - 12 * 3600 * 1000).reverse();

const tz = 'Europe/Berlin';
const fmtDay = (d: Date) =>
  new Intl.DateTimeFormat('de-DE', { weekday: 'short', day: '2-digit', month: 'short', year: 'numeric', timeZone: tz }).format(d);
const fmtTime = (d: Date) =>
  new Intl.DateTimeFormat('de-DE', { hour: '2-digit', minute: '2-digit', timeZone: tz }).format(d);

// Field metadata — label, control type, grouping. Keep keys ⊆ SHEET_FIELDS.
type FieldDef = { key: (typeof SHEET_FIELDS)[number]; label: string; area?: boolean; placeholder?: string };
const groups: { title: string; fields: FieldDef[] }[] = [
  {
    title: 'Zeitplan',
    fields: [
      { key: 'loadIn', label: 'Load-in', placeholder: 'z. B. 16:00' },
      { key: 'soundcheck', label: 'Soundcheck', placeholder: 'z. B. 17:30' },
      { key: 'doors', label: 'Einlass', placeholder: 'z. B. 19:00' },
      { key: 'stageTime', label: 'Stagetime', placeholder: 'z. B. 21:00' },
      { key: 'setLength', label: 'Set-Länge', placeholder: 'z. B. 45 Min' },
    ],
  },
  {
    title: 'Logistik',
    fields: [
      { key: 'address', label: 'Anfahrt / Adresse', area: true, placeholder: 'Venue-Adresse für Navi' },
      { key: 'parking', label: 'Parken', placeholder: 'Hof, Parkplatz, …' },
      { key: 'accommodation', label: 'Übernachtung', placeholder: 'Hotel / Schlafmöglichkeit' },
      { key: 'catering', label: 'Catering', placeholder: 'Essen, Getränke, Buyout' },
      { key: 'backline', label: 'Backline / Technik', area: true, placeholder: 'Was steht, was mitbringen' },
    ],
  },
  {
    title: 'Kontakt & Notizen',
    fields: [
      { key: 'contactOnSite', label: 'Kontakt vor Ort', placeholder: 'Name + Handy' },
      { key: 'notes', label: 'Notizen', area: true, placeholder: 'Sonstiges' },
    ],
  },
];

// Short summary line for the collapsed card.
const inputBase =
  'w-full rounded-lg border border-cream/15 bg-ink px-3 py-2 text-sm text-cream outline-none placeholder:text-cream/30 focus:border-flame';
---

<Layout title="Gig-Sheets — Swallow's Rose Crew" chrome={false}>
  <section class="mx-auto min-h-[100dvh] max-w-3xl px-6 py-16">
    <a href="/backend" class="mb-8 inline-block text-xs uppercase tracking-[0.2em] text-cream-soft transition-colors hover:text-flame">
      ← Crew-Bereich
    </a>

    <p class="mb-2 text-xs uppercase tracking-[0.3em] text-flame">Booking</p>
    <h1 class="text-5xl">Gig-Sheets</h1>
    <p class="mt-3 text-sm text-cream-soft">
      Alles fürs Show-Datum: Load-in, Zeitplan, Anfahrt, Rider. Ein Sheet pro bestätigtem Gig — alle dürfen bearbeiten.
    </p>

    {gigs.length === 0 && (
      <p class="mt-10 text-sm text-cream/40">
        Noch keine bestätigten Gigs. Sobald ein Gig in der <a href="/backend/gigs" class="text-flame underline-offset-4 hover:underline">Gig-Pipeline</a> auf „Bestätigt" steht, taucht hier sein Sheet auf.
      </p>
    )}

    {[
      { label: 'Anstehend', items: upcoming },
      { label: 'Vergangen', items: past },
    ].filter((sec) => sec.items.length).map((sec) => (
      <div class="mt-10">
        <p class="mb-3 text-xs uppercase tracking-[0.2em] text-cream/40">{sec.label} ({sec.items.length})</p>
        <div class="flex flex-col gap-4">
          {sec.items.map((gig) => {
            const sheet = sheetMap[gig.id] ?? {};
            const filled = SHEET_FIELDS.filter((f) => sheet[f]).length;
            return (
              <div class="rounded-xl border border-cream/10 bg-ink-soft/50" data-sheet data-id={gig.id}>
                <button
                  type="button"
                  data-toggle
                  class="flex w-full items-center justify-between gap-4 px-5 py-4 text-left"
                >
                  <div class="min-w-0">
                    <div class="text-sm text-flame">{fmtDay(gig.startAt)}{!gig.allDay && ` · ${fmtTime(gig.startAt)}`}</div>
                    <div class="truncate text-xl leading-tight">{gig.title}</div>
                    <div class="truncate text-sm text-cream-soft">
                      {[gig.city, gig.location].filter(Boolean).join(' · ') || 'Kein Ort hinterlegt'}
                    </div>
                  </div>
                  <div class="flex shrink-0 items-center gap-3">
                    <span data-badge class={`text-[10px] uppercase tracking-[0.2em] ${filled ? 'text-teal' : 'text-cream/30'}`}>
                      {filled ? `${filled} Feld${filled === 1 ? '' : 'er'}` : 'Leer'}
                    </span>
                    <span data-caret class="text-cream/40 transition-transform">▾</span>
                  </div>
                </button>

                <div data-body hidden class="border-t border-cream/10 px-5 py-5">
                  <form data-form class="flex flex-col gap-5">
                    {groups.map((grp) => (
                      <fieldset class="grid grid-cols-1 gap-3 sm:grid-cols-2">
                        <legend class="mb-1 text-xs uppercase tracking-[0.15em] text-cream/40 sm:col-span-2">{grp.title}</legend>
                        {grp.fields.map((fld) => (
                          <label class={`flex flex-col gap-1 text-xs uppercase tracking-wider text-cream/40 ${fld.area ? 'sm:col-span-2' : ''}`}>
                            {fld.label}
                            {fld.area ? (
                              <textarea data-field={fld.key} rows="2" placeholder={fld.placeholder} class={inputBase}>{sheet[fld.key] ?? ''}</textarea>
                            ) : (
                              <input data-field={fld.key} value={sheet[fld.key] ?? ''} placeholder={fld.placeholder} autocomplete="off" class={inputBase} />
                            )}
                          </label>
                        ))}
                      </fieldset>
                    ))}
                    <div class="flex items-center gap-4">
                      <button type="submit" data-save
                        class="rounded-lg bg-flame px-5 py-2.5 font-display text-base uppercase tracking-wide text-ink transition-colors hover:bg-flame-soft disabled:opacity-50">
                        Speichern
                      </button>
                      <p data-msg role="status" class="text-sm text-teal" hidden></p>
                    </div>
                  </form>
                </div>
              </div>
            );
          })}
        </div>
      </div>
    ))}
  </section>
</Layout>

<script>
  const FIELDS = ['loadIn','soundcheck','doors','stageTime','setLength','address','parking','accommodation','catering','backline','contactOnSite','notes'];

  document.querySelectorAll('[data-sheet]').forEach((card) => {
    const el = card as HTMLElement;
    const eventId = el.dataset.id!;
    const toggle = el.querySelector('[data-toggle]') as HTMLButtonElement;
    const body = el.querySelector('[data-body]') as HTMLElement;
    const caret = el.querySelector('[data-caret]') as HTMLElement;
    const form = el.querySelector('[data-form]') as HTMLFormElement;
    const badge = el.querySelector('[data-badge]') as HTMLElement;
    const msg = el.querySelector('[data-msg]') as HTMLElement;
    const save = el.querySelector('[data-save]') as HTMLButtonElement;

    toggle.addEventListener('click', () => {
      const open = body.hidden;
      body.hidden = !open;
      caret.style.transform = open ? 'rotate(180deg)' : '';
    });

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const payload: Record<string, string> = { eventId };
      FIELDS.forEach((f) => {
        const ctrl = form.querySelector(`[data-field="${f}"]`) as HTMLInputElement | HTMLTextAreaElement | null;
        payload[f] = ctrl ? ctrl.value.trim() : '';
      });
      save.disabled = true;
      const prev = save.textContent;
      save.textContent = 'Speichert …';
      const res = await fetch('/api/gigsheet/save', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload),
      });
      const data = await res.json().catch(() => ({}));
      save.disabled = false;
      save.textContent = prev;
      if (res.ok) {
        const filled = FIELDS.filter((f) => payload[f]).length;
        badge.textContent = filled ? `${filled} Feld${filled === 1 ? '' : 'er'}` : 'Leer';
        badge.className = `text-[10px] uppercase tracking-[0.2em] ${filled ? 'text-teal' : 'text-cream/30'}`;
        msg.textContent = 'Gespeichert.';
        msg.style.color = 'var(--color-teal)';
        msg.hidden = false;
        setTimeout(() => (msg.hidden = true), 2000);
      } else {
        msg.textContent = data.error ?? 'Speichern fehlgeschlagen.';
        msg.style.color = 'var(--color-flame)';
        msg.hidden = false;
      }
    });
  });
</script>
