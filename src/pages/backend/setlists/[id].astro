---
// Setlist editor — reorder songs via drag-and-drop, add/remove from the
// library, per-slot notes, running total. Any logged-in member may edit.
export const prerender = false;

import Layout from '../../../layouts/Layout.astro';
import { getSetlist, listSongs, fmtDuration } from '../../../lib/setlists';
import { listUpcomingEvents } from '../../../lib/events';

const user = Astro.locals.user!;
const { id } = Astro.params;
const data = id ? await getSetlist(id) : null;
if (!data) return Astro.redirect('/backend/setlists');

const { list, items } = data;
const songs = await listSongs();
const activeSongs = songs.filter((s) => s.active);
const events = await listUpcomingEvents();

const tz = 'Europe/Berlin';
const fmtDay = (d: Date) =>
  new Intl.DateTimeFormat('de-DE', { day: '2-digit', month: 'short', year: 'numeric', timeZone: tz }).format(d);
const eventOptions = events.map((e) => ({ id: e.id, label: `${fmtDay(e.startAt)} · ${e.title}${e.city ? ` (${e.city})` : ''}` }));

const totalSeconds = items.reduce((sum, it) => sum + (it.durationSeconds ?? 0), 0);
const missingDurations = items.some((it) => !it.durationSeconds);

const inputBase =
  'rounded-lg border border-cream/15 bg-ink px-4 py-3 text-cream outline-none placeholder:text-cream/30 focus:border-flame';
---

<Layout title={`${list.title} — Setlist — Swallow's Rose Crew`} chrome={false}>
  <section class="mx-auto min-h-[100dvh] max-w-3xl px-6 py-16">
    <a href="/backend/setlists" class="mb-8 inline-block text-xs uppercase tracking-[0.2em] text-cream-soft transition-colors hover:text-flame">
      ← Alle Setlists
    </a>

    <p class="mb-2 text-xs uppercase tracking-[0.3em] text-flame">Setlist</p>

    <!-- Meta -->
    <form id="meta-form" data-id={list.id}>
      <input id="m-title" value={list.title} required
        class="w-full border-0 border-b border-cream/15 bg-transparent pb-2 text-4xl text-cream outline-none focus:border-flame" />
      <div class="mt-4 grid grid-cols-1 gap-3 sm:grid-cols-2">
        <select id="m-event" class={inputBase}>
          <option value="">— kein Gig verknüpft —</option>
          {eventOptions.map((o) => <option value={o.id} selected={o.id === list.eventId}>{o.label}</option>)}
          {list.eventId && !eventOptions.some((o) => o.id === list.eventId) && (
            <option value={list.eventId} selected>Verknüpfter Gig (vergangen)</option>
          )}
        </select>
        <input id="m-notes" value={list.notes ?? ''} placeholder="Notizen zur Setlist" autocomplete="off" class={inputBase} />
      </div>
      <div class="mt-3 flex items-center gap-4">
        <button id="m-save" type="submit"
          class="rounded-lg border border-cream/15 px-4 py-2 text-xs uppercase tracking-[0.15em] text-cream-soft transition-colors hover:border-flame hover:text-flame">
          Kopf speichern
        </button>
        <p id="m-msg" role="status" class="text-sm text-teal" hidden></p>
      </div>
    </form>

    <!-- Summary -->
    <div class="mt-8 flex items-baseline justify-between border-y border-cream/10 py-3">
      <span class="text-sm text-cream-soft"><span id="count">{items.length}</span> Songs</span>
      <span class="text-sm text-cream-soft">
        Gesamt: <span id="total" class="tabular-nums text-cream">{totalSeconds > 0 ? `${fmtDuration(totalSeconds)} Min` : '—'}</span>
        {missingDurations && <span class="ml-1 text-xs text-cream/40">(unvollständig)</span>}
      </span>
    </div>

    <!-- Add song -->
    <div class="mt-5 flex flex-wrap items-center gap-3">
      <select id="add-song" class={`${inputBase} flex-1`}>
        <option value="">Song aus der Bibliothek hinzufügen …</option>
        {activeSongs.map((s) => (
          <option value={s.id} data-duration={s.durationSeconds ?? ''}>
            {s.title}{s.artist ? ` · ${s.artist}` : ''}{s.durationSeconds ? ` (${fmtDuration(s.durationSeconds)})` : ''}
          </option>
        ))}
      </select>
      <button id="add-btn"
        class="rounded-lg bg-flame px-5 py-3 font-display text-base uppercase tracking-wide text-ink transition-colors hover:bg-flame-soft disabled:opacity-50">
        + Hinzufügen
      </button>
    </div>
    {activeSongs.length === 0 && (
      <p class="mt-2 text-xs text-cream/40">
        Keine aktiven Songs in der <a href="/backend/setlists" class="text-flame">Bibliothek</a>.
      </p>
    )}

    <!-- Ordered list -->
    <ol id="list" class="mt-6 flex flex-col gap-2">
      {items.map((it, i) => (
        <li
          class="group flex items-center gap-3 rounded-xl border border-cream/10 bg-ink-soft/50 p-3"
          draggable="true"
          data-item data-item-id={it.itemId} data-duration={it.durationSeconds ?? ''}
        >
          <span data-handle class="cursor-grab select-none px-1 text-lg text-cream/30 transition-colors group-hover:text-cream/60" title="Ziehen zum Sortieren">⠿</span>
          <span data-num class="w-6 shrink-0 text-right tabular-nums text-sm text-flame">{i + 1}</span>
          <div class="min-w-0 flex-1">
            <div class="truncate">
              {it.title}{it.artist && <span class="text-cream/40"> · {it.artist}</span>}
            </div>
            <input data-note value={it.note ?? ''} placeholder="Cue / Ansage (optional)"
              class="mt-1 w-full border-0 bg-transparent text-xs text-cream/60 outline-none placeholder:text-cream/25 focus:text-cream" />
          </div>
          <span class="shrink-0 text-sm tabular-nums text-cream-soft">{fmtDuration(it.durationSeconds) || '—'}</span>
          <button data-remove class="shrink-0 rounded border border-cream/15 px-2 py-1 text-[10px] uppercase tracking-[0.15em] text-cream-soft transition-colors hover:border-flame hover:text-flame">Entf.</button>
        </li>
      ))}
    </ol>
    {items.length === 0 && <p id="empty" class="mt-4 text-sm text-cream/40">Noch keine Songs — oben aus der Bibliothek hinzufügen.</p>}
  </section>

  <script id="sl-meta" type="application/json" set:html={JSON.stringify({ id: list.id })}></script>
</Layout>

<script>
  const setlistId: string = JSON.parse(document.getElementById('sl-meta')!.textContent || '{}').id;
  const listEl = document.getElementById('list') as HTMLOListElement;

  async function post(url: string, body: unknown) {
    const res = await fetch(url, { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(body) });
    return { ok: res.ok, data: await res.json().catch(() => ({})) };
  }
  const fmt = (secs: number) => (secs > 0 ? `${Math.floor(secs / 60)}:${String(secs % 60).padStart(2, '0')}` : '');

  function recompute() {
    const rows = [...listEl.querySelectorAll('[data-item]')] as HTMLElement[];
    let total = 0;
    let missing = false;
    rows.forEach((li, i) => {
      (li.querySelector('[data-num]') as HTMLElement).textContent = String(i + 1);
      const d = Number(li.dataset.duration || 0);
      if (d) total += d;
      else missing = true;
    });
    (document.getElementById('count') as HTMLElement).textContent = String(rows.length);
    (document.getElementById('total') as HTMLElement).textContent = total > 0 ? `${fmt(total)} Min` : '—';
    document.getElementById('empty')?.remove();
  }

  function currentOrder(): string[] {
    return [...listEl.querySelectorAll('[data-item]')].map((li) => (li as HTMLElement).dataset.itemId!);
  }
  async function persistOrder() {
    const { ok } = await post('/api/setlist/items', { action: 'reorder', setlistId, order: currentOrder() });
    if (!ok) alert('Reihenfolge konnte nicht gespeichert werden.');
  }

  // ── Drag and drop ──
  let dragEl: HTMLElement | null = null;
  function wireDnd(li: HTMLElement) {
    li.addEventListener('dragstart', () => {
      dragEl = li;
      setTimeout(() => li.classList.add('opacity-40'), 0);
    });
    li.addEventListener('dragend', () => {
      li.classList.remove('opacity-40');
      dragEl = null;
      recompute();
      persistOrder();
    });
  }
  listEl.addEventListener('dragover', (e) => {
    e.preventDefault();
    if (!dragEl) return;
    const after = [...listEl.querySelectorAll('[data-item]:not(.opacity-40)')].find((el) => {
      const box = (el as HTMLElement).getBoundingClientRect();
      return e.clientY < box.top + box.height / 2;
    }) as HTMLElement | undefined;
    if (after) listEl.insertBefore(dragEl, after);
    else listEl.appendChild(dragEl);
  });

  // ── Per-row wiring ──
  function wireRow(li: HTMLElement) {
    wireDnd(li);
    const itemId = li.dataset.itemId!;
    const note = li.querySelector('[data-note]') as HTMLInputElement;
    let noteTimer: ReturnType<typeof setTimeout>;
    const saveNote = async () => {
      await post('/api/setlist/items', { action: 'note', itemId, note: note.value.trim() });
    };
    note.addEventListener('input', () => {
      clearTimeout(noteTimer);
      noteTimer = setTimeout(saveNote, 600);
    });
    note.addEventListener('blur', saveNote);
    li.querySelector('[data-remove]')?.addEventListener('click', async () => {
      const { ok, data } = await post('/api/setlist/items', { action: 'remove', itemId });
      if (ok) {
        li.remove();
        recompute();
      } else alert(data.error ?? 'Entfernen fehlgeschlagen.');
    });
  }
  listEl.querySelectorAll('[data-item]').forEach((li) => wireRow(li as HTMLElement));

  // ── Add song ──
  const addSel = document.getElementById('add-song') as HTMLSelectElement;
  const addBtn = document.getElementById('add-btn') as HTMLButtonElement;
  addBtn?.addEventListener('click', async () => {
    const songId = addSel.value;
    if (!songId) return;
    const opt = addSel.selectedOptions[0];
    const title = opt.textContent!.trim();
    const duration = opt.dataset.duration || '';
    addBtn.disabled = true;
    const { ok, data } = await post('/api/setlist/items', { action: 'add', setlistId, songId });
    addBtn.disabled = false;
    if (!ok || !data.id) {
      alert(data.error ?? 'Konnte nicht hinzufügen.');
      return;
    }
    const li = document.createElement('li');
    li.className = 'group flex items-center gap-3 rounded-xl border border-cream/10 bg-ink-soft/50 p-3';
    li.draggable = true;
    li.dataset.item = '';
    li.dataset.itemId = data.id;
    li.dataset.duration = duration;
    const durLabel = duration ? fmt(Number(duration)) : '—';
    li.innerHTML = `
      <span data-handle class="cursor-grab select-none px-1 text-lg text-cream/30 transition-colors group-hover:text-cream/60" title="Ziehen zum Sortieren">⠿</span>
      <span data-num class="w-6 shrink-0 text-right tabular-nums text-sm text-flame"></span>
      <div class="min-w-0 flex-1">
        <div class="truncate"></div>
        <input data-note placeholder="Cue / Ansage (optional)" class="mt-1 w-full border-0 bg-transparent text-xs text-cream/60 outline-none placeholder:text-cream/25 focus:text-cream" />
      </div>
      <span class="shrink-0 text-sm tabular-nums text-cream-soft">${durLabel}</span>
      <button data-remove class="shrink-0 rounded border border-cream/15 px-2 py-1 text-[10px] uppercase tracking-[0.15em] text-cream-soft transition-colors hover:border-flame hover:text-flame">Entf.</button>`;
    (li.querySelector('.truncate') as HTMLElement).textContent = title;
    listEl.appendChild(li);
    wireRow(li);
    recompute();
    addSel.value = '';
  });

  // ── Meta save ──
  const metaForm = document.getElementById('meta-form') as HTMLFormElement;
  const metaMsg = document.getElementById('m-msg') as HTMLElement;
  metaForm.addEventListener('submit', async (e) => {
    e.preventDefault();
    const title = (document.getElementById('m-title') as HTMLInputElement).value.trim();
    if (!title) return;
    const { ok, data } = await post('/api/setlist/save', {
      id: setlistId,
      title,
      eventId: (document.getElementById('m-event') as HTMLSelectElement).value || null,
      notes: (document.getElementById('m-notes') as HTMLInputElement).value.trim(),
    });
    metaMsg.textContent = ok ? 'Gespeichert.' : (data.error ?? 'Fehler.');
    metaMsg.style.color = ok ? 'var(--color-teal)' : 'var(--color-flame)';
    metaMsg.hidden = false;
    setTimeout(() => (metaMsg.hidden = true), 2000);
  });
</script>
