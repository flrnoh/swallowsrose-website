---
// Shared band calendar — agenda view, create/edit/delete, personal iCal feed.
// Any logged-in member may edit.
export const prerender = false;

import Layout from '../../layouts/Layout.astro';
import { listEvents, getOrCreateIcalToken, EVENT_TYPES } from '../../lib/events';

const user = Astro.locals.user!;
const events = await listEvents();
const token = await getOrCreateIcalToken(user.id);

const site = Astro.url.origin;
const feedUrl = `${site}/api/calendar/${token}.ics`;
const webcalUrl = feedUrl.replace(/^https?:/, 'webcal:');

const tz = 'Europe/Berlin';
const fmtDay = (d: Date) =>
  new Intl.DateTimeFormat('de-DE', { weekday: 'short', day: '2-digit', month: 'short', timeZone: tz }).format(d);
const fmtTime = (d: Date) =>
  new Intl.DateTimeFormat('de-DE', { hour: '2-digit', minute: '2-digit', timeZone: tz }).format(d);
const monthKey = (d: Date) =>
  new Intl.DateTimeFormat('de-DE', { month: 'long', year: 'numeric', timeZone: tz }).format(d);

const typeLabel: Record<string, string> = { gig: 'Gig', probe: 'Probe', sonstiges: 'Termin' };

// Group the (already date-sorted) events by month for the agenda.
const groups: { label: string; items: typeof events }[] = [];
for (const e of events) {
  const label = monthKey(e.startAt);
  const g = groups.at(-1);
  if (g && g.label === label) g.items.push(e);
  else groups.push({ label, items: [e] });
}

// Serialised for the client (edit prefill). Dates as ISO.
const clientEvents = events.map((e) => ({
  id: e.id,
  type: e.type,
  title: e.title,
  startAt: e.startAt.toISOString(),
  endAt: e.endAt ? e.endAt.toISOString() : null,
  allDay: e.allDay,
  location: e.location ?? '',
  city: e.city ?? '',
  ticketUrl: e.ticketUrl ?? '',
  notes: e.notes ?? '',
  isPublic: e.isPublic,
}));
---

<Layout title="Kalender — Swallow's Rose Crew" chrome={false}>
  <section class="mx-auto min-h-[100dvh] max-w-3xl px-6 py-16">
    <a href="/backend" class="mb-8 inline-block text-xs uppercase tracking-[0.2em] text-cream-soft transition-colors hover:text-flame">
      ← Crew-Bereich
    </a>

    <p class="mb-2 text-xs uppercase tracking-[0.3em] text-flame">Band</p>
    <h1 class="text-5xl">Kalender</h1>
    <p class="mt-3 text-sm text-cream-soft">Gigs, Proben & Termine — geteilt mit der ganzen Crew.</p>

    <!-- iCal abonnieren -->
    <div class="mt-8 rounded-xl border border-teal/30 bg-teal/5 p-5">
      <h2 class="text-2xl">In deinen Kalender abonnieren</h2>
      <p class="mt-2 text-sm text-cream-soft">
        Einmal abonnieren — dann synct dein Handy-/Mac-Kalender die Band-Termine automatisch.
      </p>
      <div class="mt-4 flex flex-wrap gap-3">
        <a href={webcalUrl}
          class="rounded-lg bg-teal px-4 py-2 font-display text-base uppercase tracking-wide text-ink transition-opacity hover:opacity-90">
          Abonnieren
        </a>
        <button id="copy-feed" data-url={feedUrl}
          class="rounded-lg border border-cream/15 px-4 py-2 text-xs uppercase tracking-[0.15em] text-cream-soft transition-colors hover:border-teal hover:text-teal">
          Feed-URL kopieren
        </button>
      </div>
      <p class="mt-3 break-all text-[11px] text-cream/30">{feedUrl}</p>
    </div>

    <!-- Termin anlegen / bearbeiten -->
    <form id="event-form" class="mt-8 rounded-xl border border-cream/10 bg-ink-soft/50 p-5">
      <h2 id="form-title" class="text-2xl">Neuer Termin</h2>
      <input type="hidden" id="ev-id" />
      <div class="mt-4 grid grid-cols-1 gap-3 sm:grid-cols-2">
        <select id="ev-type" class="rounded-lg border border-cream/15 bg-ink px-4 py-3 text-cream outline-none focus:border-flame">
          {EVENT_TYPES.map((t) => <option value={t} selected={t === 'gig'}>{typeLabel[t]}</option>)}
        </select>
        <input id="ev-title" required placeholder="Titel" autocomplete="off"
          class="rounded-lg border border-cream/15 bg-ink px-4 py-3 text-cream outline-none placeholder:text-cream/30 focus:border-flame" />
        <label class="flex flex-col gap-1 text-xs uppercase tracking-wider text-cream/40">Beginn
          <input id="ev-start" required type="datetime-local"
            class="rounded-lg border border-cream/15 bg-ink px-4 py-2.5 text-cream outline-none focus:border-flame" />
        </label>
        <label class="flex flex-col gap-1 text-xs uppercase tracking-wider text-cream/40">Ende (optional)
          <input id="ev-end" type="datetime-local"
            class="rounded-lg border border-cream/15 bg-ink px-4 py-2.5 text-cream outline-none focus:border-flame" />
        </label>
        <input id="ev-location" placeholder="Ort / Venue" autocomplete="off"
          class="rounded-lg border border-cream/15 bg-ink px-4 py-3 text-cream outline-none placeholder:text-cream/30 focus:border-flame" />
        <input id="ev-city" placeholder="Stadt" autocomplete="off"
          class="rounded-lg border border-cream/15 bg-ink px-4 py-3 text-cream outline-none placeholder:text-cream/30 focus:border-flame" />
        <input id="ev-ticket" placeholder="Ticket-Link (optional)" autocomplete="off"
          class="rounded-lg border border-cream/15 bg-ink px-4 py-3 text-cream outline-none placeholder:text-cream/30 focus:border-flame sm:col-span-2" />
        <textarea id="ev-notes" placeholder="Notizen (optional)" rows="2"
          class="rounded-lg border border-cream/15 bg-ink px-4 py-3 text-cream outline-none placeholder:text-cream/30 focus:border-flame sm:col-span-2"></textarea>
      </div>
      <div class="mt-4 flex flex-wrap items-center gap-x-6 gap-y-3">
        <label class="flex items-center gap-2 text-sm text-cream-soft">
          <input id="ev-allday" type="checkbox" class="accent-flame" /> Ganztägig
        </label>
        <label class="flex items-center gap-2 text-sm text-cream-soft">
          <input id="ev-public" type="checkbox" class="accent-flame" /> Öffentlich (im Tourkalender auf der Website)
        </label>
      </div>
      <div class="mt-5 flex items-center gap-4">
        <button id="ev-submit" type="submit"
          class="rounded-lg bg-flame px-5 py-3 font-display text-lg uppercase tracking-wide text-ink transition-colors hover:bg-flame-soft disabled:opacity-50">
          Speichern
        </button>
        <button id="ev-cancel" type="button" hidden
          class="text-xs uppercase tracking-[0.15em] text-cream-soft hover:text-flame">Abbrechen</button>
        <p id="ev-msg" role="status" class="text-sm text-teal" hidden></p>
      </div>
    </form>

    <!-- Agenda -->
    <div class="mt-10">
      <h2 class="mb-4 text-2xl">Termine ({events.length})</h2>
      {events.length === 0 && <p class="text-sm text-cream/40">Noch keine Termine — leg oben den ersten an.</p>}
      {
        groups.map((g) => (
          <div class="mb-6">
            <p class="mb-2 text-xs uppercase tracking-[0.2em] text-cream/40">{g.label}</p>
            <ul class="flex flex-col gap-2">
              {g.items.map((e) => (
                <li class="flex flex-wrap items-center gap-x-4 gap-y-2 rounded-xl border border-cream/10 bg-ink-soft/50 p-4" data-ev data-id={e.id}>
                  <div class="w-16 shrink-0 text-center">
                    <div class="text-sm text-flame">{fmtDay(e.startAt)}</div>
                    <div class="text-xs text-cream/40">{e.allDay ? 'ganztägig' : fmtTime(e.startAt)}</div>
                  </div>
                  <div class="min-w-0 flex-1">
                    <div class="flex items-center gap-2">
                      <span class="text-[10px] uppercase tracking-[0.2em] text-cream/40">{typeLabel[e.type]}</span>
                      {e.isPublic && <span class="text-[10px] uppercase tracking-[0.2em] text-teal">öffentlich</span>}
                    </div>
                    <div class="truncate text-lg">{e.title}</div>
                    {(e.location || e.city) && (
                      <div class="truncate text-sm text-cream-soft">{[e.location, e.city].filter(Boolean).join(' · ')}</div>
                    )}
                  </div>
                  <div class="flex gap-2">
                    <button data-edit class="rounded-lg border border-cream/15 px-3 py-1.5 text-xs uppercase tracking-[0.15em] text-cream-soft transition-colors hover:border-flame hover:text-flame">Bearbeiten</button>
                    <button data-del class="rounded-lg border border-cream/15 px-3 py-1.5 text-xs uppercase tracking-[0.15em] text-cream-soft transition-colors hover:border-flame hover:text-flame">Löschen</button>
                  </div>
                </li>
              ))}
            </ul>
          </div>
        ))
      }
    </div>
  </section>

  <script id="events-data" type="application/json" set:html={JSON.stringify(clientEvents)}></script>
</Layout>

<script>
  type Ev = {
    id: string; type: string; title: string; startAt: string; endAt: string | null;
    allDay: boolean; location: string; city: string; ticketUrl: string; notes: string; isPublic: boolean;
  };
  const events: Ev[] = JSON.parse(document.getElementById('events-data')!.textContent || '[]');

  const $ = <T extends HTMLElement = HTMLElement>(id: string) => document.getElementById(id) as T;
  const form = $('event-form') as HTMLFormElement;
  const msg = $('ev-msg');
  const submit = $('ev-submit') as HTMLButtonElement;
  const cancel = $('ev-cancel') as HTMLButtonElement;
  const formTitle = $('form-title');

  // datetime-local wants local "YYYY-MM-DDTHH:mm"; derive from an ISO string.
  const toLocalInput = (iso: string | null) => {
    if (!iso) return '';
    const d = new Date(iso);
    const p = (n: number) => String(n).padStart(2, '0');
    return `${d.getFullYear()}-${p(d.getMonth() + 1)}-${p(d.getDate())}T${p(d.getHours())}:${p(d.getMinutes())}`;
  };

  function showMsg(text: string, ok = true) {
    msg.textContent = text;
    msg.style.color = ok ? 'var(--color-teal)' : 'var(--color-flame)';
    msg.hidden = false;
  }

  function resetForm() {
    ($('ev-id') as HTMLInputElement).value = '';
    (['ev-title', 'ev-start', 'ev-end', 'ev-location', 'ev-city', 'ev-ticket', 'ev-notes'] as const).forEach(
      (id) => (($(id) as HTMLInputElement).value = ''),
    );
    ($('ev-type') as HTMLSelectElement).value = 'gig';
    ($('ev-allday') as HTMLInputElement).checked = false;
    ($('ev-public') as HTMLInputElement).checked = false;
    formTitle.textContent = 'Neuer Termin';
    cancel.hidden = true;
    msg.hidden = true;
  }

  function fillForm(e: Ev) {
    ($('ev-id') as HTMLInputElement).value = e.id;
    ($('ev-type') as HTMLSelectElement).value = e.type;
    ($('ev-title') as HTMLInputElement).value = e.title;
    ($('ev-start') as HTMLInputElement).value = toLocalInput(e.startAt);
    ($('ev-end') as HTMLInputElement).value = toLocalInput(e.endAt);
    ($('ev-location') as HTMLInputElement).value = e.location;
    ($('ev-city') as HTMLInputElement).value = e.city;
    ($('ev-ticket') as HTMLInputElement).value = e.ticketUrl;
    ($('ev-notes') as HTMLTextAreaElement).value = e.notes;
    ($('ev-allday') as HTMLInputElement).checked = e.allDay;
    ($('ev-public') as HTMLInputElement).checked = e.isPublic;
    formTitle.textContent = 'Termin bearbeiten';
    cancel.hidden = false;
    form.scrollIntoView({ behavior: 'smooth', block: 'start' });
  }

  async function post(url: string, body: unknown) {
    const res = await fetch(url, {
      method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(body),
    });
    return { ok: res.ok, data: await res.json().catch(() => ({})) };
  }

  cancel.addEventListener('click', resetForm);

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    const startLocal = ($('ev-start') as HTMLInputElement).value;
    const endLocal = ($('ev-end') as HTMLInputElement).value;
    if (!($('ev-title') as HTMLInputElement).value.trim() || !startLocal) return;

    const payload: Record<string, unknown> = {
      id: ($('ev-id') as HTMLInputElement).value || undefined,
      type: ($('ev-type') as HTMLSelectElement).value,
      title: ($('ev-title') as HTMLInputElement).value.trim(),
      startAt: new Date(startLocal).toISOString(),
      endAt: endLocal ? new Date(endLocal).toISOString() : null,
      allDay: ($('ev-allday') as HTMLInputElement).checked,
      location: ($('ev-location') as HTMLInputElement).value.trim(),
      city: ($('ev-city') as HTMLInputElement).value.trim(),
      ticketUrl: ($('ev-ticket') as HTMLInputElement).value.trim(),
      notes: ($('ev-notes') as HTMLTextAreaElement).value.trim(),
      isPublic: ($('ev-public') as HTMLInputElement).checked,
    };

    submit.disabled = true;
    submit.textContent = 'Speichert …';
    const url = payload.id ? '/api/events/update' : '/api/events/create';
    const { ok, data } = await post(url, payload);
    submit.disabled = false;
    submit.textContent = 'Speichern';

    if (ok) {
      showMsg('Gespeichert.');
      setTimeout(() => location.reload(), 600);
    } else {
      showMsg(data.error ?? 'Speichern fehlgeschlagen.', false);
    }
  });

  document.querySelectorAll('[data-ev]').forEach((li) => {
    const id = (li as HTMLElement).dataset.id!;
    li.querySelector('[data-edit]')?.addEventListener('click', () => {
      const ev = events.find((x) => x.id === id);
      if (ev) fillForm(ev);
    });
    li.querySelector('[data-del]')?.addEventListener('click', async () => {
      const title = li.querySelector('.truncate')?.textContent ?? 'diesen Termin';
      if (!confirm(`„${title}" wirklich löschen?`)) return;
      const { ok, data } = await post('/api/events/delete', { id });
      if (ok) li.remove();
      else alert(data.error ?? 'Löschen fehlgeschlagen.');
    });
  });

  // Feed-URL kopieren
  $('copy-feed')?.addEventListener('click', async (e) => {
    const btn = e.currentTarget as HTMLButtonElement;
    try {
      await navigator.clipboard.writeText(btn.dataset.url || '');
      const t = btn.textContent;
      btn.textContent = 'Kopiert ✓';
      setTimeout(() => (btn.textContent = t), 1500);
    } catch {
      alert(btn.dataset.url);
    }
  });
</script>
