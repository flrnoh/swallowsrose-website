---
// Tour planner (Phase 2) — generative. Block a window, pick N shows + a home
// base + radius, and a nearest-neighbour + 2-opt pass over the contact
// coordinates proposes a compact, drivable route of booking targets to pitch.
// Fully client-side (snappy re-generate on every control change); egress-free.
//
// Honest limit: we have no per-festival dates, so this proposes the
// geographically best *targets to contact* for the window, not dated shows.
export const prerender = false;

import Layout from '../../../layouts/Layout.astro';
import { listContacts, KIND_LABEL } from '../../../lib/contacts';
import { geocode, projectUnit, MAP_ASPECT } from '../../../lib/geo';
import outline from '../../../data/dach-outline.json';
import festivals from '../../../data/festivals.json';

// Festival-Wissensbasis: sourceKey → { month, outdoor, verified, window? }.
// `verified` = Monat + Indoor/Outdoor gegen die Festivalseite geprüft; sonst
// heuristisch (dem Crew klar als „~ geschätzt" gekennzeichnet). Siehe
// scripts/build-festivals.mjs.
type Fest = { month: number; outdoor: boolean; verified: boolean; window?: string };
const FEST = festivals as Record<string, Fest>;

const contacts = await listContacts();

const W = 420;
const H = Math.round(W / MAP_ASPECT);
const PAD = 26;

// Candidates: contacts with coordinates (festivals + promoters), pre-projected.
const candidates = contacts
  .map((c) => ({ c, co: geocode(c.city) }))
  .filter((x) => x.co)
  .map(({ c, co }) => {
    const [ux, uy] = projectUnit(co!);
    const f = c.sourceKey ? FEST[c.sourceKey] : undefined;
    return {
      name: c.name,
      city: c.city ?? '',
      kind: c.kind,
      email: c.email ?? '',
      // Festival-Wissen für Datums-Filter + Anzeige; null = kein/unbekanntes Festival.
      month: f ? f.month : null,
      outdoor: f ? f.outdoor : null,
      verified: f ? f.verified : false,
      window: f?.window ?? '',
      lat: co![0],
      lng: co![1],
      ux: +ux.toFixed(4),
      uy: +uy.toFixed(4),
    };
  });

// Anchor options: a fixed home base + every candidate city.
const HOME = { label: 'Zuhause (Bayerischer Wald)', lat: 49.0165, lng: 13.2371 };
const [hux, huy] = projectUnit([HOME.lat, HOME.lng]);
const cityMap = new Map<string, { label: string; lat: number; lng: number; ux: number; uy: number }>();
for (const c of candidates) {
  if (!cityMap.has(c.city)) cityMap.set(c.city, { label: c.city, lat: c.lat, lng: c.lng, ux: c.ux, uy: c.uy });
}
const anchors = [
  { ...HOME, ux: +hux.toFixed(4), uy: +huy.toFixed(4) },
  ...[...cityMap.values()].sort((a, b) => a.label.localeCompare(b.label, 'de')),
];
---

<Layout title="Tour generieren — Swallow's Rose Crew" chrome={false}>
  <section class="mx-auto min-h-[100dvh] max-w-3xl px-6 py-16">
    <a href="/backend/tourplaner" class="mb-8 inline-block text-xs uppercase tracking-[0.2em] text-cream-soft transition-colors hover:text-flame">
      ← Tourplaner
    </a>

    <p class="mb-2 text-xs uppercase tracking-[0.3em] text-flame">Generator</p>
    <h1 class="text-5xl">Tour generieren</h1>
    <p class="mt-3 text-sm text-cream-soft">Startpunkt, Umkreis und Anzahl Shows wählen — die passenden Kontakte stellen sich zur kürzesten fahrbaren Route zusammen.</p>

    <div class="mt-8 rounded-xl border border-cream/10 bg-ink-soft/50 p-5">
      <div class="grid grid-cols-1 gap-4 sm:grid-cols-2">
        <label class="flex flex-col gap-1 text-xs uppercase tracking-wider text-cream/40 sm:col-span-2">Startpunkt
          <select id="t-anchor" class="rounded-lg border border-cream/15 bg-ink px-4 py-3 text-cream outline-none focus:border-flame">
            {anchors.map((a, i) => <option value={i}>{a.label}</option>)}
          </select>
        </label>
        <label class="flex flex-col gap-1 text-xs uppercase tracking-wider text-cream/40">Umkreis · <span id="t-radius-out" class="text-flame normal-case">250 km</span>
          <input id="t-radius" type="range" min="50" max="600" step="25" value="250" class="mt-2 accent-flame" />
        </label>
        <label class="flex flex-col gap-1 text-xs uppercase tracking-wider text-cream/40">Anzahl Shows · <span id="t-n-out" class="text-flame normal-case">5</span>
          <input id="t-n" type="range" min="2" max="14" step="1" value="5" class="mt-2 accent-flame" />
        </label>
        <label class="flex flex-col gap-1 text-xs uppercase tracking-wider text-cream/40">Zeitraum von
          <input id="t-from" type="date" class="rounded-lg border border-cream/15 bg-ink px-4 py-2.5 text-cream outline-none focus:border-flame" />
        </label>
        <label class="flex flex-col gap-1 text-xs uppercase tracking-wider text-cream/40">bis
          <input id="t-to" type="date" class="rounded-lg border border-cream/15 bg-ink px-4 py-2.5 text-cream outline-none focus:border-flame" />
        </label>
      </div>
      <div class="mt-4 flex flex-wrap items-center gap-4 text-sm text-cream-soft">
        <label class="flex items-center gap-2"><input id="t-fest" type="checkbox" checked class="accent-flame" /> Festivals</label>
        <label class="flex items-center gap-2"><input id="t-vera" type="checkbox" checked class="accent-flame" /> Veranstalter</label>
        <label class="flex items-center gap-2"><input id="t-mail" type="checkbox" checked class="accent-flame" /> nur mit E-Mail</label>
      </div>
      <p class="mt-3 text-xs leading-relaxed text-cream/30">Festival-Badges: ☀ Open-Air / ⌂ Halle · <span class="text-teal">✓ verlässlich</span> = Termin geprüft · <span class="text-flame/70">~ geschätzt</span> = Monat unbestätigt, vor dem Anschreiben kurz prüfen. Der Zeitraum filtert Festivals nach Saison (Venues/Veranstalter bleiben ganzjährig).</p>
    </div>

    <div class="mt-4 grid grid-cols-3 gap-3">
      <div class="rounded-xl bg-ink-soft/60 p-4">
        <div class="text-xs uppercase tracking-wider text-cream/40">Shows</div>
        <div id="m-stops" class="mt-1 text-3xl">–</div>
      </div>
      <div class="rounded-xl bg-ink-soft/60 p-4">
        <div class="text-xs uppercase tracking-wider text-cream/40">Luftlinie</div>
        <div id="m-km" class="mt-1 text-3xl">–</div>
      </div>
      <div class="rounded-xl bg-ink-soft/60 p-4">
        <div class="text-xs uppercase tracking-wider text-cream/40">Kandidaten</div>
        <div id="m-pool" class="mt-1 text-3xl">–</div>
      </div>
    </div>

    <div class="mt-4 rounded-xl border border-cream/10 bg-ink-soft/40 p-3">
      <svg viewBox={`0 0 ${W} ${H}`} class="mx-auto block h-auto w-full max-w-sm" role="img" aria-label="Generierte Tour-Route">
        <path d={outline.ch} fill="none" stroke="rgb(255 255 255 / 0.07)" stroke-width="1" stroke-linejoin="round" />
        <path d={outline.at} fill="none" stroke="rgb(255 255 255 / 0.07)" stroke-width="1" stroke-linejoin="round" />
        <path d={outline.cz} fill="none" stroke="rgb(255 255 255 / 0.07)" stroke-width="1" stroke-linejoin="round" />
        <path d={outline.de} fill="rgb(255 255 255 / 0.045)" stroke="rgb(255 255 255 / 0.18)" stroke-width="1.2" stroke-linejoin="round" />
        <g id="route-layer"></g>
      </svg>
    </div>

    <div class="mt-6 flex flex-wrap items-center gap-3">
      <p id="plan-hint" class="mr-auto text-xs text-cream/30"></p>
      <button id="regen" class="rounded-lg border border-cream/15 px-3 py-1.5 text-xs uppercase tracking-[0.15em] text-cream-soft transition-colors hover:border-flame hover:text-flame">↻ Neu vorschlagen</button>
      <button id="copy-mails" class="rounded-lg border border-cream/15 px-3 py-1.5 text-xs uppercase tracking-[0.15em] text-cream-soft transition-colors hover:border-flame hover:text-flame">E-Mails kopieren</button>
      <a id="sammel-mail" href="#" class="rounded-lg bg-flame px-3 py-1.5 text-xs uppercase tracking-[0.15em] text-ink transition-colors hover:bg-flame-soft">Sammelmail ↗</a>
    </div>

    <ol id="plan-list" class="mt-3 flex flex-col gap-2"></ol>

    <div id="add-wrap" hidden class="mt-4">
      <p class="mb-2 text-xs uppercase tracking-[0.2em] text-cream/40">Weitere in der Nähe hinzufügen</p>
      <div id="add-list" class="flex flex-wrap gap-2"></div>
    </div>
  </section>

  <script id="cand-data" type="application/json" set:html={JSON.stringify(candidates)}></script>
  <script id="anchor-data" type="application/json" set:html={JSON.stringify(anchors)}></script>
  <script id="dims-data" type="application/json" set:html={JSON.stringify({ W, H, PAD })}></script>
  <script id="kindlabel-data" type="application/json" set:html={JSON.stringify(KIND_LABEL)}></script>
</Layout>

<script>
  type Cand = { name: string; city: string; kind: string; email: string; month: number | null; outdoor: boolean | null; verified: boolean; window: string; lat: number; lng: number; ux: number; uy: number };
  type Anchor = { label: string; lat: number; lng: number; ux: number; uy: number };
  const CAND: Cand[] = JSON.parse(document.getElementById('cand-data')!.textContent || '[]');
  const ANCHORS: Anchor[] = JSON.parse(document.getElementById('anchor-data')!.textContent || '[]');
  const { W, H, PAD } = JSON.parse(document.getElementById('dims-data')!.textContent || '{}');
  const KL: Record<string, string> = JSON.parse(document.getElementById('kindlabel-data')!.textContent || '{}');

  const $ = (id: string) => document.getElementById(id)!;
  const esc = (s: string) => s.replace(/[&<>"]/g, (m) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;' }[m]!));
  // Festival-Badge: Open-Air/Halle + Fenster + verlässlich/geschätzt. Nur für
  // Festivals mit bekannten Daten; „~ geschätzt" warnt vor ungeprüften Monaten.
  const festBadge = (c: Cand) => {
    if (c.kind !== 'festival' || c.outdoor === null) return '';
    const venue = c.outdoor ? '☀ Open-Air' : '⌂ Halle';
    const win = c.window ? ` · ${esc(c.window)}` : '';
    const trust = c.verified
      ? '<span class="text-teal" title="Termin gegen die Festivalseite verifiziert">✓ verlässlich</span>'
      : '<span class="text-flame/70" title="Monat nur geschätzt — vor dem Anschreiben kurz prüfen">~ geschätzt</span>';
    return `<span class="inline-flex items-center gap-1.5 rounded-full border border-cream/10 bg-ink/40 px-2.5 py-0.5 text-xs text-cream-soft">${venue}${win} · ${trust}</span>`;
  };
  const sx = (ux: number) => PAD + ux * (W - 2 * PAD);
  const sy = (uy: number) => PAD + uy * (H - 2 * PAD);
  const hav = (a: { lat: number; lng: number }, b: { lat: number; lng: number }) => {
    const R = 6371, r = (x: number) => (x * Math.PI) / 180;
    const dLat = r(b.lat - a.lat), dLng = r(b.lng - a.lng);
    const s = Math.sin(dLat / 2) ** 2 + Math.cos(r(a.lat)) * Math.cos(r(b.lat)) * Math.sin(dLng / 2) ** 2;
    return 2 * R * Math.asin(Math.sqrt(s));
  };
  const routeLen = (anchor: Anchor, r: Cand[]) => {
    if (!r.length) return 0;
    let d = hav(anchor, r[0]);
    for (let i = 1; i < r.length; i++) d += hav(r[i - 1], r[i]);
    return d;
  };
  function twoOpt(anchor: Anchor, route: Cand[]) {
    if (route.length < 3) return route;
    let best = route.slice(), bl = routeLen(anchor, best), improved = true;
    while (improved) {
      improved = false;
      for (let i = 0; i < best.length - 1; i++)
        for (let k = i + 1; k < best.length; k++) {
          const cand = best.slice(0, i).concat(best.slice(i, k + 1).reverse(), best.slice(k + 1));
          const cl = routeLen(anchor, cand);
          if (cl < bl - 1e-9) { best = cand; bl = cl; improved = true; }
        }
    }
    return best;
  }
  // Festival-Monat im gewählten Fenster? (Jahreswechsel wird berücksichtigt.)
  const inMonths = (m: number, fm: number, tm: number) => (fm <= tm ? m >= fm && m <= tm : m >= fm || m <= tm);

  // Pitch-Mail. Alle Belege sind echt (Bio/Label/Tour-Historie). Die Zahlen-Zeile
  // füllt die Band EINMAL in PROOF — leer = Zeile fällt sauber weg (kein
  // Platzhalter landet im Versand). Betreff/Text ziehen Fenster + Region live rein.
  const PROOF = ''; // TODO Florian: echte Belege, z.B. "Über 15.000 monatliche Hörer auf Spotify · ~200–400 Besucher pro Show."
  const fmtLong = (d: string) => new Date(d).toLocaleDateString('de-DE', { day: '2-digit', month: 'long' });
  const buildSubject = () => "Swallow's Rose — Booking-Anfrage (Melodic Punk · Uncle M Music)";
  function buildBody() {
    const from = ($('t-from') as HTMLInputElement).value, to = ($('t-to') as HTMLInputElement).value;
    const region = /^Zuhause/.test(ANCHOR.label) ? 'Süddeutschland' : ANCHOR.label;
    const fenster = from && to ? `von ${fmtLong(from)} bis ${fmtLong(to)} ` : '';
    return [
      'Hallo,',
      '',
      'wir sind Swallow’s Rose — Melodic Punk aus Niederbayern, aktuell mit dem neuen Album „The Beginning“ (Uncle M Music, zuvor SBÄM Records) unterwegs. Auf der Bühne standen wir u. a. schon mit Dropkick Murphys, Flogging Molly und Less Than Jake.',
      ...(PROOF ? ['', PROOF] : []),
      '',
      `Für eine kompakte Tour ${fenster}rund um ${region} suchen wir noch Slots — euer Festival bzw. eure Location würde perfekt in die Route passen. Wir machen euch das Ja leicht:`,
      '• Headliner oder Support — wie es bei euch am besten reinpasst.',
      '• Faire, verhandelbare Gage; verlässlich, pünktlich, professionelles Auftreten.',
      '• Eigene Anlage/Backline möglich, wenn’s hilft.',
      '',
      'Hört rein & seht uns live: https://swallowsrose.com (Musik, Live-Videos, Pressekit).',
      '',
      'Sagt kurz Bescheid, ob’s passt — wir richten die Route nach euren Terminen.',
      '',
      'Punk’s not dead,',
      'Swallow’s Rose',
    ].join('\n');
  }

  let ANCHOR: Anchor = ANCHORS[0];
  let POOL: Cand[] = [];
  let current: Cand[] = [];

  function filterPool() {
    ANCHOR = ANCHORS[+($('t-anchor') as HTMLSelectElement).value];
    const radius = +($('t-radius') as HTMLInputElement).value;
    const kinds: string[] = [];
    if (($('t-fest') as HTMLInputElement).checked) kinds.push('festival');
    if (($('t-vera') as HTMLInputElement).checked) kinds.push('veranstalter');
    const mailOnly = ($('t-mail') as HTMLInputElement).checked;
    const from = ($('t-from') as HTMLInputElement).value, to = ($('t-to') as HTMLInputElement).value;
    const df = from && to ? { fm: new Date(from).getUTCMonth() + 1, tm: new Date(to).getUTCMonth() + 1 } : null;
    $('t-radius-out').textContent = `${radius} km`;
    $('t-n-out').textContent = ($('t-n') as HTMLInputElement).value;
    POOL = CAND.filter((c) => {
      if (!kinds.includes(c.kind)) return false;
      if (mailOnly && !c.email) return false;
      if (hav(ANCHOR, c) > radius) return false;
      // Datumsfenster gilt nur für Festivals (Venues sind nicht saisongebunden).
      if (df && c.kind === 'festival') { if (c.month == null) return false; if (!inMonths(c.month, df.fm, df.tm)) return false; }
      return true;
    });
    $('m-pool').textContent = String(POOL.length);
  }

  function autoFill() {
    const n = +($('t-n') as HTMLInputElement).value;
    const rest = POOL.slice(), chosen: Cand[] = [];
    let cur: { lat: number; lng: number } = ANCHOR;
    while (chosen.length < n && rest.length) {
      let bi = 0, bd = Infinity;
      for (let i = 0; i < rest.length; i++) { const d = hav(cur, rest[i]); if (d < bd) { bd = d; bi = i; } }
      chosen.push(rest[bi]); cur = rest[bi]; rest.splice(bi, 1);
    }
    current = twoOpt(ANCHOR, chosen);
  }

  function render() {
    const legs = current.map((c, i) => Math.round(hav(i === 0 ? ANCHOR : current[i - 1], c)));
    const total = legs.reduce((a, b) => a + b, 0);
    $('m-stops').textContent = String(current.length);
    $('m-km').textContent = current.length ? `${total.toLocaleString('de-DE')} km` : '–';

    const proj = (c: { ux: number; uy: number }): [number, number] => [sx(c.ux), sy(c.uy)];
    let svg = '';
    if (current.length) {
      const pathPts = [ANCHOR, ...current].map((c, i) => { const [x, y] = proj(c); return `${i ? 'L' : 'M'}${x.toFixed(1)} ${y.toFixed(1)}`; }).join(' ');
      svg += `<path d="${pathPts}" fill="none" stroke="var(--color-flame)" stroke-width="2" stroke-linejoin="round" stroke-linecap="round" opacity="0.9"/>`;
      const [hx, hy] = proj(ANCHOR);
      svg += `<circle cx="${hx}" cy="${hy}" r="6" fill="none" stroke="var(--color-cream-soft)" stroke-width="2"/>`;
      current.forEach((c, i) => {
        const [x, y] = proj(c);
        svg += `<circle cx="${x}" cy="${y}" r="8.5" fill="var(--color-flame)"/><text x="${x}" y="${y + 3.5}" text-anchor="middle" font-size="10" font-weight="600" fill="var(--color-ink)">${i + 1}</text>`;
      });
    }
    $('route-layer').innerHTML = svg;

    $('plan-list').innerHTML = current.length
      ? current.map((c, i) => `
        <li>
          ${i > 0 ? `<div class="flex items-center gap-2 py-1 pl-5 text-xs text-cream/30"><span class="text-flame/60">↓</span> ${legs[i].toLocaleString('de-DE')} km</div>` : ''}
          <div class="flex flex-wrap items-center gap-x-3 gap-y-1 rounded-xl border border-cream/10 bg-ink-soft/50 p-4">
            <span class="flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-flame font-display text-sm text-ink">${i + 1}</span>
            <span class="text-lg">${esc(c.name)}</span>
            <span class="text-sm text-cream-soft">· ${esc(c.city)} · ${esc(KL[c.kind] || c.kind)}</span>
            ${festBadge(c)}
            ${c.email ? `<a href="mailto:${esc(c.email)}" class="text-sm text-teal transition-colors hover:text-flame">${esc(c.email)}</a>` : ''}
            <button data-remove="${i}" aria-label="Stopp entfernen" class="ml-auto shrink-0 rounded-lg border border-cream/15 px-2.5 py-1 text-xs text-cream-soft transition-colors hover:border-flame hover:text-flame">✕</button>
          </div>
        </li>`).join('')
      : `<li class="text-sm text-cream/40">Keine Kandidaten — Radius vergrößern, Datum weiten oder Filter lockern.</li>`;
    $('plan-list').querySelectorAll('[data-remove]').forEach((b) =>
      b.addEventListener('click', () => { current.splice(+(b as HTMLElement).dataset.remove!, 1); current = twoOpt(ANCHOR, current); render(); }),
    );

    // „Weitere in der Nähe": Pool ohne bereits gewählte, nach Distanz zum Start.
    const chosen = new Set(current);
    const near = POOL.filter((c) => !chosen.has(c)).sort((a, b) => hav(ANCHOR, a) - hav(ANCHOR, b)).slice(0, 8);
    ($('add-wrap') as HTMLElement).hidden = near.length === 0;
    $('add-list').innerHTML = near.map((c, i) =>
      `<button data-add="${i}" class="rounded-full border border-cream/15 px-3 py-1.5 text-xs text-cream-soft transition-colors hover:border-flame hover:text-flame">+ ${esc(c.name)} · ${esc(c.city)} · ${Math.round(hav(ANCHOR, c))} km</button>`,
    ).join('');
    $('add-list').querySelectorAll('[data-add]').forEach((b) =>
      b.addEventListener('click', () => { current.push(near[+(b as HTMLElement).dataset.add!]); current = twoOpt(ANCHOR, current); render(); }),
    );

    const mails = current.map((c) => c.email).filter(Boolean);
    const sammel = $('sammel-mail') as HTMLAnchorElement;
    sammel.href = mails.length ? `mailto:?bcc=${mails.join(',')}&subject=${encodeURIComponent(buildSubject())}&body=${encodeURIComponent(buildBody())}` : '#';
    sammel.style.opacity = mails.length ? '1' : '0.4';
    sammel.style.pointerEvents = mails.length ? 'auto' : 'none';

    const from = ($('t-from') as HTMLInputElement).value, to = ($('t-to') as HTMLInputElement).value;
    const fmt = (d: string) => new Date(d).toLocaleDateString('de-DE', { day: '2-digit', month: 'short' });
    $('plan-hint').textContent = current.length
      ? (from && to ? `${current.length} Shows · ${fmt(from)}–${fmt(to)} · ab ${ANCHOR.label}` : `${current.length} Shows · ab ${ANCHOR.label}`)
      : '';
  }

  function generate() { filterPool(); autoFill(); render(); }

  ['t-anchor', 't-radius', 't-n', 't-fest', 't-vera', 't-mail', 't-from', 't-to'].forEach((id) =>
    $(id).addEventListener('input', generate),
  );
  $('regen').addEventListener('click', generate);
  $('copy-mails').addEventListener('click', async () => {
    const mails = current.map((c) => c.email).filter(Boolean).join(', ');
    if (!mails) return;
    try { await navigator.clipboard.writeText(mails); const b = $('copy-mails'); const t = b.textContent; b.textContent = 'Kopiert ✓'; setTimeout(() => (b.textContent = t), 1200); } catch {}
  });

  generate();
</script>
