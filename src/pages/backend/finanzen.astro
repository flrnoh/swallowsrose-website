---
// Finanzen — shared band ledger. Income (gigs, merch, invoices) and expenses,
// with payment method (SumUp/Bar/…), optional gig link, live balance and a
// per-member Gagen-Split. Any logged-in member may edit.
export const prerender = false;

import Layout from '../../layouts/Layout.astro';
import {
  listEntries, summarize, getMemberCount, fmtEuro,
  KIND_LABEL, CATEGORIES, METHODS, categoryLabel, methodLabel,
} from '../../lib/finance';
import { listGigs, CONFIRMED_STATUSES } from '../../lib/events';

const user = Astro.locals.user!;
const entries = await listEntries();
const memberCount = await getMemberCount();
const sum = summarize(entries, memberCount);

const gigs = (await listGigs())
  .filter((g) => CONFIRMED_STATUSES.includes(g.status as any))
  .sort((a, b) => b.startAt.getTime() - a.startAt.getTime());

const tz = 'Europe/Berlin';
const fmtDay = (d: Date) =>
  new Intl.DateTimeFormat('de-DE', { day: '2-digit', month: 'short', year: 'numeric', timeZone: tz }).format(d);
const dateInput = (d: Date) => {
  const p = (n: number) => String(n).padStart(2, '0');
  return `${d.getFullYear()}-${p(d.getMonth() + 1)}-${p(d.getDate())}`;
};
const gigTitle = new Map(gigs.map((g) => [g.id, `${fmtDay(g.startAt)} · ${g.title}${g.city ? ` (${g.city})` : ''}`]));

const gigOptions = gigs.map((g) => ({ id: g.id, label: `${fmtDay(g.startAt)} · ${g.title}${g.city ? ` (${g.city})` : ''}` }));

// Entries prepared for the client (edit prefill).
const clientEntries = entries.map((e) => ({
  id: e.id,
  kind: e.kind,
  category: e.category,
  title: e.title,
  amount: (e.amountCents / 100).toFixed(2),
  method: e.method ?? '',
  date: dateInput(e.occurredAt),
  eventId: e.eventId ?? '',
  notes: e.notes ?? '',
}));

// Today, for the date input default.
const today = dateInput(new Date());

const inputBase =
  'rounded-lg border border-cream/15 bg-ink px-4 py-3 text-cream outline-none placeholder:text-cream/30 focus:border-flame';
---

<Layout title="Finanzen — Swallow's Rose Crew" chrome={false}>
  <section class="mx-auto min-h-[100dvh] max-w-3xl px-6 py-16">
    <a href="/backend" class="mb-8 inline-block text-xs uppercase tracking-[0.2em] text-cream-soft transition-colors hover:text-flame">
      ← Crew-Bereich
    </a>

    <p class="mb-2 text-xs uppercase tracking-[0.3em] text-flame">Kasse</p>
    <h1 class="text-5xl">Finanzen</h1>
    <p class="mt-3 text-sm text-cream-soft">
      Gemeinsames Kassenbuch: Gagen, Merch & Rechnungen (SumUp), Ausgaben — mit Kassenstand und Gagen-Split.
    </p>

    <!-- Summary -->
    <div class="mt-8 grid grid-cols-2 gap-3 sm:grid-cols-4">
      <div class="rounded-xl border border-cream/10 bg-ink-soft/50 p-4">
        <div class="text-[10px] uppercase tracking-[0.2em] text-cream/40">Einnahmen</div>
        <div class="mt-1 text-xl tabular-nums text-teal">{fmtEuro(sum.incomeCents)}</div>
      </div>
      <div class="rounded-xl border border-cream/10 bg-ink-soft/50 p-4">
        <div class="text-[10px] uppercase tracking-[0.2em] text-cream/40">Ausgaben</div>
        <div class="mt-1 text-xl tabular-nums text-flame">{fmtEuro(sum.expenseCents)}</div>
      </div>
      <div class="rounded-xl border border-flame/30 bg-flame/10 p-4">
        <div class="text-[10px] uppercase tracking-[0.2em] text-cream/40">Kassenstand</div>
        <div class={`mt-1 text-xl tabular-nums ${sum.balanceCents < 0 ? 'text-flame' : 'text-cream'}`}>{fmtEuro(sum.balanceCents)}</div>
      </div>
      <div class="rounded-xl border border-cream/10 bg-ink-soft/50 p-4">
        <div class="text-[10px] uppercase tracking-[0.2em] text-cream/40">Pro Kopf ÷ {sum.memberCount}</div>
        <div class={`mt-1 text-xl tabular-nums ${sum.perMemberCents < 0 ? 'text-flame' : 'text-teal'}`}>{fmtEuro(sum.perMemberCents)}</div>
      </div>
    </div>

    {sum.incomeByMethod.length > 0 && (
      <p class="mt-3 text-xs text-cream/50">
        Einnahmen nach Zahlungsart: {sum.incomeByMethod.map((m, i) => (
          <span>{i > 0 ? ' · ' : ''}<span class="text-cream-soft">{m.label}</span> {fmtEuro(m.cents)}</span>
        ))}
      </p>
    )}

    <!-- Add / edit -->
    <form id="fin-form" class="mt-8 rounded-xl border border-cream/10 bg-ink-soft/50 p-5">
      <input type="hidden" id="f-id" />
      <div class="flex items-center justify-between">
        <h2 id="form-title" class="text-2xl">Buchung hinzufügen</h2>
        <div class="flex overflow-hidden rounded-lg border border-cream/15 text-sm">
          <button type="button" data-kind="einnahme" class="px-4 py-1.5 font-display uppercase tracking-wide">Einnahme</button>
          <button type="button" data-kind="ausgabe" class="px-4 py-1.5 font-display uppercase tracking-wide">Ausgabe</button>
        </div>
      </div>

      <div class="mt-4 grid grid-cols-1 gap-3 sm:grid-cols-2">
        <input id="f-title" required placeholder="Bezeichnung (z. B. Gage Backstage / T-Shirts)" autocomplete="off"
          class={`${inputBase} sm:col-span-2`} />
        <label class="flex flex-col gap-1 text-xs uppercase tracking-wider text-cream/40">Betrag (€)
          <input id="f-amount" required inputmode="decimal" placeholder="0,00" autocomplete="off" class={inputBase} />
        </label>
        <label class="flex flex-col gap-1 text-xs uppercase tracking-wider text-cream/40">Datum
          <input id="f-date" required type="date" value={today} class={inputBase} />
        </label>
        <label class="flex flex-col gap-1 text-xs uppercase tracking-wider text-cream/40">Kategorie
          <select id="f-category" class={inputBase}></select>
        </label>
        <label class="flex flex-col gap-1 text-xs uppercase tracking-wider text-cream/40">Zahlungsart
          <select id="f-method" class={inputBase}>
            {METHODS.map((m) => <option value={m.value} selected={m.value === 'sumup'}>{m.label}</option>)}
          </select>
        </label>
        <label class="flex flex-col gap-1 text-xs uppercase tracking-wider text-cream/40 sm:col-span-2">Gig (optional)
          <select id="f-event" class={inputBase}>
            <option value="">— kein Gig —</option>
            {gigOptions.map((o) => <option value={o.id}>{o.label}</option>)}
          </select>
        </label>
        <input id="f-notes" placeholder="Notiz (optional)" autocomplete="off" class={`${inputBase} sm:col-span-2`} />
      </div>

      <div class="mt-5 flex items-center gap-4">
        <button id="f-submit" type="submit"
          class="rounded-lg bg-flame px-5 py-3 font-display text-lg uppercase tracking-wide text-ink transition-colors hover:bg-flame-soft disabled:opacity-50">
          Speichern
        </button>
        <button id="f-cancel" type="button" hidden class="text-xs uppercase tracking-[0.15em] text-cream-soft hover:text-flame">Abbrechen</button>
        <p id="f-msg" role="status" class="text-sm text-teal" hidden></p>
      </div>
    </form>

    <!-- Bulk import (paste from a spreadsheet) -->
    <div class="mt-6 rounded-xl border border-cream/10 bg-ink-soft/40">
      <button type="button" id="imp-toggle" class="flex w-full items-center justify-between gap-4 px-5 py-4 text-left">
        <span class="text-lg">Mehrere auf einmal — aus Tabelle einfügen</span>
        <span id="imp-caret" class="text-cream/40 transition-transform">▾</span>
      </button>
      <div id="imp-body" hidden class="border-t border-cream/10 px-5 py-5">
        <p class="text-xs text-cream/50">
          Zeilen aus Excel/Sheets kopieren und hier einfügen — Spalten <b>Tab-getrennt</b>:
          <span class="text-cream-soft">Datum · Art · Betrag · Bemerkung</span>. Datum als T/M/JJJJ oder JJJJ-MM-TT.
          Die Kategorie wird aus „Art" erraten (nachträglich pro Buchung änderbar).
        </p>
        <div class="mt-3 flex flex-wrap items-center gap-3">
          <div class="flex overflow-hidden rounded-lg border border-cream/15 text-sm">
            <button type="button" data-imp-kind="einnahme" class="px-4 py-1.5 font-display uppercase tracking-wide">Einnahmen</button>
            <button type="button" data-imp-kind="ausgabe" class="px-4 py-1.5 font-display uppercase tracking-wide">Ausgaben</button>
          </div>
          <select id="imp-method" class={inputBase}>
            <option value="">Zahlungsart: —</option>
            {METHODS.map((m) => <option value={m.value}>{m.label}</option>)}
          </select>
        </div>
        <textarea id="imp-text" rows="7"
          placeholder={"9/1/2025\tLabel\t5593\tWerbekosten + Vinyls UncleM"}
          class={`${inputBase} mt-3 w-full font-mono text-xs`}></textarea>
        <div class="mt-3 flex flex-wrap items-center gap-4">
          <button type="button" id="imp-preview"
            class="rounded-lg border border-cream/15 px-4 py-2 text-sm uppercase tracking-[0.15em] text-cream-soft transition-colors hover:border-flame hover:text-flame">
            Vorschau
          </button>
          <button type="button" id="imp-submit" hidden
            class="rounded-lg bg-flame px-5 py-2.5 font-display text-base uppercase tracking-wide text-ink transition-colors hover:bg-flame-soft disabled:opacity-50">
            Übernehmen
          </button>
          <p id="imp-msg" role="status" class="text-sm text-teal" hidden></p>
        </div>
        <div id="imp-preview-wrap" hidden class="mt-4 overflow-x-auto">
          <table class="w-full border-collapse text-sm">
            <thead>
              <tr class="text-left text-[10px] uppercase tracking-wider text-cream/40">
                <th class="border-b border-cream/10 py-1 pr-3">Datum</th>
                <th class="border-b border-cream/10 py-1 pr-3">Kategorie</th>
                <th class="border-b border-cream/10 py-1 pr-3 text-right">Betrag</th>
                <th class="border-b border-cream/10 py-1">Bezeichnung</th>
              </tr>
            </thead>
            <tbody id="imp-preview-body"></tbody>
          </table>
        </div>
      </div>
    </div>

    <!-- Ledger -->
    <div class="mt-10">
      <h2 class="text-2xl">Buchungen</h2>
      {entries.length === 0 && <p class="mt-3 text-sm text-cream/40">Noch keine Buchungen — leg oben die erste an.</p>}
      <ul class="mt-4 flex flex-col gap-2">
        {entries.map((e) => (
          <li class="flex flex-wrap items-center gap-x-3 gap-y-1 rounded-xl border border-cream/10 bg-ink-soft/50 p-4" data-entry data-id={e.id}>
            <div class="w-20 shrink-0 text-xs text-cream/40">{fmtDay(e.occurredAt)}</div>
            <div class="min-w-0 flex-1">
              <div class="truncate">{e.title}</div>
              <div class="truncate text-xs text-cream/40">
                {categoryLabel(e.category)}
                {e.method ? ` · ${methodLabel(e.method)}` : ''}
                {e.eventId && gigTitle.has(e.eventId) ? ` · ${gigTitle.get(e.eventId)}` : ''}
                {e.notes ? ` · ${e.notes}` : ''}
              </div>
            </div>
            <div class={`shrink-0 tabular-nums ${e.kind === 'einnahme' ? 'text-teal' : 'text-flame'}`}>
              {e.kind === 'einnahme' ? '+' : '−'}{fmtEuro(e.amountCents)}
            </div>
            <div class="flex shrink-0 items-center gap-2">
              <button data-edit class="rounded border border-cream/15 px-2 py-1 text-[10px] uppercase tracking-[0.15em] text-cream-soft transition-colors hover:border-flame hover:text-flame">Bearb.</button>
              <button data-del class="rounded border border-cream/15 px-2 py-1 text-[10px] uppercase tracking-[0.15em] text-cream-soft transition-colors hover:border-flame hover:text-flame">Löschen</button>
            </div>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <script id="fin-entries" type="application/json" set:html={JSON.stringify(clientEntries)}></script>
  <script id="fin-categories" type="application/json" set:html={JSON.stringify(CATEGORIES)}></script>
</Layout>

<script>
  type Entry = {
    id: string; kind: string; category: string; title: string; amount: string;
    method: string; date: string; eventId: string; notes: string;
  };
  type Cat = { value: string; label: string };
  const entries: Entry[] = JSON.parse(document.getElementById('fin-entries')!.textContent || '[]');
  const CATEGORIES: Record<string, Cat[]> = JSON.parse(document.getElementById('fin-categories')!.textContent || '{}');

  const $ = (id: string) => document.getElementById(id) as HTMLInputElement;
  const sel = (id: string) => document.getElementById(id) as unknown as HTMLSelectElement;
  async function post(url: string, body: unknown) {
    const res = await fetch(url, { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(body) });
    return { ok: res.ok, data: await res.json().catch(() => ({})) };
  }
  function parseEuro(text: string): number | null {
    let t = text.trim().replace(/[€\s]/g, '');
    if (!t) return null;
    if (t.includes(',') && t.includes('.')) {
      if (t.lastIndexOf(',') > t.lastIndexOf('.')) t = t.replace(/\./g, '').replace(',', '.');
      else t = t.replace(/,/g, '');
    } else if (t.includes(',')) t = t.replace(',', '.');
    const n = Number(t);
    if (isNaN(n) || n < 0) return null;
    return Math.round(n * 100);
  }
  const showMsg = (t: string, ok = true) => {
    const el = document.getElementById('f-msg') as HTMLElement;
    el.textContent = t;
    el.style.color = ok ? 'var(--color-teal)' : 'var(--color-flame)';
    el.hidden = false;
  };

  const form = document.getElementById('fin-form') as HTMLFormElement;
  const submit = document.getElementById('f-submit') as HTMLButtonElement;
  const cancel = document.getElementById('f-cancel') as HTMLButtonElement;
  const formTitle = document.getElementById('form-title') as HTMLElement;
  const kindBtns = [...document.querySelectorAll('[data-kind]')] as HTMLButtonElement[];

  let kind: 'einnahme' | 'ausgabe' = 'einnahme';
  const ACTIVE = 'bg-flame text-ink';
  const INACTIVE = 'text-cream-soft hover:text-flame';

  function rebuildCategories(selected?: string) {
    const cats = CATEGORIES[kind] ?? [];
    sel('f-category').innerHTML = '';
    for (const c of cats) {
      const opt = document.createElement('option');
      opt.value = c.value;
      opt.textContent = c.label;
      if (c.value === selected) opt.selected = true;
      sel('f-category').appendChild(opt);
    }
  }
  function setKind(k: 'einnahme' | 'ausgabe', selectedCat?: string) {
    kind = k;
    kindBtns.forEach((b) => {
      const on = b.dataset.kind === k;
      b.className = `px-4 py-1.5 font-display uppercase tracking-wide ${on ? ACTIVE : INACTIVE}`;
    });
    rebuildCategories(selectedCat);
  }
  kindBtns.forEach((b) => b.addEventListener('click', () => setKind(b.dataset.kind as 'einnahme' | 'ausgabe')));
  setKind('einnahme');

  function resetForm() {
    $('f-id').value = '';
    $('f-title').value = '';
    $('f-amount').value = '';
    $('f-notes').value = '';
    sel('f-method').value = 'sumup';
    sel('f-event').value = '';
    setKind('einnahme');
    formTitle.textContent = 'Buchung hinzufügen';
    cancel.hidden = true;
    (document.getElementById('f-msg') as HTMLElement).hidden = true;
  }
  cancel.addEventListener('click', resetForm);

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    const title = $('f-title').value.trim();
    const amountCents = parseEuro($('f-amount').value);
    const date = $('f-date').value;
    if (!title) return;
    if (amountCents === null || amountCents <= 0) return showMsg('Betrag ungültig (z. B. 250 oder 12,50).', false);
    if (!date) return showMsg('Datum fehlt.', false);
    const payload = {
      id: $('f-id').value || undefined,
      kind,
      category: sel('f-category').value,
      title,
      amountCents,
      method: sel('f-method').value,
      occurredAt: new Date(date).toISOString(),
      eventId: sel('f-event').value || null,
      notes: $('f-notes').value.trim(),
    };
    submit.disabled = true;
    submit.textContent = 'Speichert …';
    const { ok, data } = await post('/api/finance/save', payload);
    submit.disabled = false;
    submit.textContent = 'Speichern';
    if (ok) {
      showMsg('Gespeichert.');
      setTimeout(() => location.reload(), 500);
    } else showMsg(data.error ?? 'Speichern fehlgeschlagen.', false);
  });

  document.querySelectorAll('[data-entry]').forEach((li) => {
    const id = (li as HTMLElement).dataset.id!;
    li.querySelector('[data-edit]')?.addEventListener('click', () => {
      const en = entries.find((x) => x.id === id);
      if (!en) return;
      $('f-id').value = en.id;
      setKind(en.kind as 'einnahme' | 'ausgabe', en.category);
      $('f-title').value = en.title;
      $('f-amount').value = en.amount.replace('.', ',');
      $('f-date').value = en.date;
      sel('f-method').value = en.method || 'sumup';
      sel('f-event').value = en.eventId;
      $('f-notes').value = en.notes;
      formTitle.textContent = 'Buchung bearbeiten';
      cancel.hidden = false;
      form.scrollIntoView({ behavior: 'smooth', block: 'center' });
    });
    li.querySelector('[data-del]')?.addEventListener('click', async () => {
      const title = li.querySelector('.truncate')?.textContent ?? 'diese Buchung';
      if (!confirm(`„${title}" wirklich löschen?`)) return;
      const { ok, data } = await post('/api/finance/delete', { id });
      if (ok) location.reload();
      else alert(data.error ?? 'Löschen fehlgeschlagen.');
    });
  });

  // ── Bulk import (paste from spreadsheet) ──
  const catLabel = (kind: string, value: string) =>
    (CATEGORIES[kind] ?? []).find((c) => c.value === value)?.label ?? value;

  // Guess a category from the free-text "Art" column, per kind.
  const CAT_RULES: Record<string, [RegExp, string][]> = {
    ausgabe: [
      [/tank|bus|sprit|fahrt|diesel|benzin|maut|km|zug|bahn|flug/i, 'fahrt'],
      [/hotel|übernacht|ubernacht|unterkunft|airbnb|pension|hostel/i, 'unterkunft'],
      [/cater|verpfleg|essen|getränk|getrank|buyout/i, 'verpflegung'],
      [/mixing|master|studio|produktion|recording|aufnahme|technik|tontechnik|\bpa\b|licht|light|sound/i, 'produktion'],
      [/merch/i, 'merch-einkauf'],
      [/label|werbe|promo|marketing|flyer|plakat|vinyl|anzeige|ad\b/i, 'werbung'],
      [/equip|gitarre|saiten|string|gear|instrument|\bamp\b|\bbox\b|cable/i, 'equipment'],
      [/gebühr|gebuhr|\bfee\b|beitrag|gema|steuer|versicher/i, 'gebuehren'],
    ],
    einnahme: [
      [/gage|honorar|fee\b/i, 'gage'],
      [/merch/i, 'merch'],
      [/zuschuss|förder|forder|subvention|grant|spende/i, 'zuschuss'],
    ],
  };
  function mapCategory(kind: string, art: string): string {
    for (const [re, cat] of CAT_RULES[kind] ?? []) if (re.test(art)) return cat;
    return 'sonstiges';
  }
  const pad = (s: string) => s.padStart(2, '0');
  function parseDate(s: string): string | null {
    s = s.trim();
    let m = s.match(/^(\d{1,2})[\/.](\d{1,2})[\/.](\d{4})$/); // T/M/JJJJ or T.M.JJJJ
    if (m) return `${m[3]}-${pad(m[2])}-${pad(m[1])}`;
    m = s.match(/^(\d{4})-(\d{1,2})-(\d{1,2})$/); // JJJJ-MM-TT
    if (m) return `${m[1]}-${pad(m[2])}-${pad(m[3])}`;
    return null;
  }
  const fmtCents = (c: number) =>
    new Intl.NumberFormat('de-DE', { style: 'currency', currency: 'EUR' }).format(c / 100);

  type Row = { date: string | null; cents: number | null; category: string; title: string; error: string };
  function parseRows(text: string, kind: string): Row[] {
    return text
      .split('\n')
      .map((l) => l.replace(/\r$/, ''))
      .filter((l) => l.trim())
      .filter((l, i) => !(i === 0 && /^\s*datum\b/i.test(l))) // skip header
      .map((line) => {
        let parts = line.split('\t').map((c) => c.trim());
        if (parts.length < 3) parts = line.split(';').map((c) => c.trim());
        const [dateRaw = '', art = '', amountRaw = '', ...rest] = parts;
        const date = parseDate(dateRaw);
        const cents = parseEuro(amountRaw);
        const title = (rest.join(' ').trim() || art).trim();
        const errs: string[] = [];
        if (!date) errs.push('Datum');
        if (cents === null || cents <= 0) errs.push('Betrag');
        if (!title) errs.push('Bezeichnung');
        return { date, cents, category: mapCategory(kind, art), title, error: errs.join(', ') };
      });
  }

  const impToggle = document.getElementById('imp-toggle') as HTMLButtonElement;
  const impBody = document.getElementById('imp-body') as HTMLElement;
  const impCaret = document.getElementById('imp-caret') as HTMLElement;
  const impText = document.getElementById('imp-text') as HTMLTextAreaElement;
  const impPreviewBtn = document.getElementById('imp-preview') as HTMLButtonElement;
  const impSubmit = document.getElementById('imp-submit') as HTMLButtonElement;
  const impMsg = document.getElementById('imp-msg') as HTMLElement;
  const impWrap = document.getElementById('imp-preview-wrap') as HTMLElement;
  const impPreviewBody = document.getElementById('imp-preview-body') as HTMLElement;
  const impKindBtns = [...document.querySelectorAll('[data-imp-kind]')] as HTMLButtonElement[];

  let impKind: 'einnahme' | 'ausgabe' = 'ausgabe';
  function setImpKind(k: 'einnahme' | 'ausgabe') {
    impKind = k;
    impKindBtns.forEach((b) => {
      const on = b.dataset.impKind === k;
      b.className = `px-4 py-1.5 font-display uppercase tracking-wide ${on ? 'bg-flame text-ink' : 'text-cream-soft hover:text-flame'}`;
    });
    if (impText.value.trim()) renderPreview();
  }
  impKindBtns.forEach((b) => b.addEventListener('click', () => setImpKind(b.dataset.impKind as 'einnahme' | 'ausgabe')));
  setImpKind('ausgabe');

  impToggle.addEventListener('click', () => {
    const open = impBody.hidden;
    impBody.hidden = !open;
    impCaret.style.transform = open ? 'rotate(180deg)' : '';
  });

  let impValid: Row[] = [];
  function renderPreview() {
    const rows = parseRows(impText.value, impKind);
    impValid = rows.filter((r) => !r.error);
    impPreviewBody.innerHTML = '';
    for (const r of rows) {
      const tr = document.createElement('tr');
      tr.className = r.error ? 'text-flame' : 'text-cream-soft';
      const cells = [
        r.date ?? '—',
        r.error && r.error.includes('Datum') ? '—' : catLabel(impKind, r.category),
        r.cents != null ? fmtCents(r.cents) : '—',
        r.error ? `${r.title || '—'} — Fehler: ${r.error}` : r.title,
      ];
      tr.innerHTML = `
        <td class="border-b border-cream/5 py-1 pr-3 whitespace-nowrap">${cells[0]}</td>
        <td class="border-b border-cream/5 py-1 pr-3 whitespace-nowrap">${cells[1]}</td>
        <td class="border-b border-cream/5 py-1 pr-3 text-right tabular-nums whitespace-nowrap">${cells[2]}</td>
        <td class="border-b border-cream/5 py-1"></td>`;
      (tr.children[3] as HTMLElement).textContent = cells[3];
      impPreviewBody.appendChild(tr);
    }
    impWrap.hidden = rows.length === 0;
    const bad = rows.length - impValid.length;
    impMsg.textContent = `${impValid.length} gültig${bad ? `, ${bad} mit Fehler (werden übersprungen)` : ''}.`;
    impMsg.style.color = 'var(--color-teal)';
    impMsg.hidden = rows.length === 0;
    impSubmit.hidden = impValid.length === 0;
    impSubmit.textContent = `${impValid.length} übernehmen`;
  }
  impPreviewBtn.addEventListener('click', renderPreview);

  impSubmit.addEventListener('click', async () => {
    if (impValid.length === 0) return;
    const method = (document.getElementById('imp-method') as HTMLSelectElement).value || null;
    const entries = impValid.map((r) => ({
      kind: impKind,
      category: r.category,
      title: r.title,
      amountCents: r.cents,
      method,
      occurredAt: `${r.date}T12:00:00.000Z`,
    }));
    impSubmit.disabled = true;
    impSubmit.textContent = 'Importiert …';
    const { ok, data } = await post('/api/finance/import', { entries });
    impSubmit.disabled = false;
    if (ok) {
      impMsg.textContent = `${data.count} Buchungen importiert.`;
      setTimeout(() => location.reload(), 700);
    } else {
      impMsg.textContent = data.error ?? 'Import fehlgeschlagen.';
      impMsg.style.color = 'var(--color-flame)';
    }
  });
</script>
