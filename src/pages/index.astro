---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import Music from '../components/Music.astro';
import About from '../components/About.astro';
import Tour from '../components/Tour.astro';
import Merch from '../components/Merch.astro';
import Footer from '../components/Footer.astro';
import Marquee from '../components/Marquee.astro';
---

<Layout>
  <Hero />
  <Marquee
    items={[
      "The Beginning",
      "Out Now",
      "Uncle M Music",
      "Swallow's Rose",
      "Punk Rock from Bavaria",
    ]}
    speed={38}
  />
  <Music />
  <About />
  <Tour />
  <Marquee
    items={[
      "Tour 2026",
      "Festival Season",
      "Soizfest",
      "Rock am Hinkelhof",
      "EMS Noise Rockfest",
      "See You On The Road",
    ]}
    speed={45}
  />
  <Merch />
  <Footer />
</Layout>
