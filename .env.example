# ── Member area (Crew-Login) ──────────────────────────────────────────────
# Copy to .env and fill in for production. Locally you can leave these unset:
# no DATABASE_URL → in-process PGlite; no SMTP → magic link printed to console.

# Neon Postgres connection string (prod). Unset locally → PGlite (./.pglite).
DATABASE_URL=

# Session signing secret. Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=

# Public base URL of the site (prod). Locally defaults to http://localhost:4321.
BETTER_AUTH_URL=https://swallowsrose.com

# Brevo SMTP for sending login links (prod). Unset → links go to the console.
BREVO_SMTP_HOST=smtp-relay.brevo.com
BREVO_SMTP_USER=
BREVO_SMTP_PASS=
# From-address for login mails. Must be a sender/domain verified in Brevo.
MAIL_FROM="Swallow's Rose <crew@swallowsrose.com>"

# Band roster as JSON — set ONLY in Vercel (this repo is public, no real emails
# in source). The deploy build reconciles members from this on every deploy.
# Example:
# CREW_MEMBERS=[{"name":"Dominik","email":"dominik@…","role":"member","instrument":"Vocals"}]
CREW_MEMBERS=

# Contact address book as JSON — set ONLY in Vercel (this repo is public, no real
# third-party emails/phones in source). The deploy build reconciles the /backend/
# kontakte directory from this on every deploy (idempotent over sourceKey).
# Example:
# CREW_CONTACTS=[{"sourceKey":"drive:tourdates:bands-united","name":"Bands United","kind":"veranstalter","person":"Hans","email":"booking@…","city":"Wörgl (AT)"}]
CREW_CONTACTS=

# Invoice sender data as JSON — the band's own legally-required issuer details for
# the Rechnungen tool on /backend/finanzen. Set ONLY in Vercel (Steuernummer/IBAN
# don't belong in this public repo). Until set, the invoice PDF shows placeholders
# and the UI warns. Korbinian fills this in. Fields (all optional except the first two):
#   senderName            legal issuer (band GbR / person), appears as the sender
#   senderLines           address lines, e.g. ["Musterstraße 1","12345 Musterstadt"]
#   taxNumber             Steuernummer (Pflicht, wenn keine USt-IdNr.)
#   vatId                 USt-IdNr. (bei Regelbesteuerung)
#   email, phone, website
#   accountHolder, iban, bic, bankName   (Bankverbindung)
#   defaultTaxMode        "kleinunternehmer" (§19, keine USt) | "regel" (mit USt)
#   defaultTaxRatePercent 19 (oder 7) — nur relevant bei "regel"
#   defaultDueDays        Zahlungsziel in Tagen (z. B. 14)
#   kleinunternehmerNote  §19-Hinweistext auf der Rechnung
#   paymentNote           Standard-Zahlungshinweis unter den Positionen
# Example:
# INVOICE_SETTINGS={"senderName":"Swallow's Rose GbR","senderLines":["Musterstraße 1","12345 Musterstadt"],"taxNumber":"123/456/78910","email":"crew@swallowsrose.com","accountHolder":"Swallow's Rose GbR","iban":"DE00 0000 0000 0000 0000 00","bic":"XXXXDEXXX","bankName":"Musterbank","defaultTaxMode":"kleinunternehmer","defaultDueDays":14}
INVOICE_SETTINGS=
